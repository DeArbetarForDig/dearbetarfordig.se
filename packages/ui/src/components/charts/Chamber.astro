  [17, 460, 340],
  [18, 530, 360],
  [19, 670, 360],
  [20, 740, 340],
  [21, 810, 320],
  [22, 880, 290],
  [23, 930, 240],
  [24, 970, 190],
  [25, 1010, 140],
