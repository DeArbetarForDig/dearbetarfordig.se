  [77, 880, 620],
  [78, 950, 600],
  [79, 1020, 580],
  [80, 1090, 550],
  [81, 1160, 510],
]

const VOTE_FILL: Record<string, string> = {
  ja: 'var(--vote-ja)',
  nej: 'var(--vote-nej)',
  avstar: 'var(--vote-avstar)',
  franvarande: 'var(--vote-franvarande)',
}

function partiVar(parti: string): string {
  return `var(--parti-${parti.toLowerCase()}, var(--parti-ovriga))`
}

const voteMap = new Map(votes.map((v) => [v.politikerId, v.rost]))
const seatMap = new Map(seats.map((s) => [s.nummer, s]))
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="-10 -8 1290 718"
  role="img"
  aria-label={`G\u00f6teborgs kommunfullm\u00e4ktige \u2014 ${seats.length} ledam\u00f6ter`}
  class:list={['w-full h-auto block', className]}
>
  <defs>
    <clipPath id="daf-seat-clip"><rect x="0" y="0" width="60" height="40" rx="8" /></clipPath>
  </defs>
  {SEAT_POS.map(([num, x, y]) => {
    const seat = seatMap.get(num)
    if (!seat) return null
    const rost = voteMap.get(seat.politikerId)
    const cardFill = mode === 'vote' && rost ? (VOTE_FILL[rost] || 'var(--vote-franvarande)') : partiVar(seat.parti)
    return (
      <g class="daf-seat" transform={`translate(${x} ${y})`}>
        <title>{`${num}. ${seat.namn} (${seat.parti})${rost ? ` \u2014 ${rost}` : ''}`}</title>
        <g clip-path="url(#daf-seat-clip)">
          <rect x="0" y="0" width="60" height="40" fill={cardFill} />
          <text x="12" y="17" font-size="13" font-weight="600" fill="#fff" text-anchor="middle" font-family="var(--font-mono)">{num}</text>
          <circle cx="40" cy="20" r="17" fill={partiVar(seat.parti)} />
          <text x="40" y="21" font-size="14" font-weight="700" fill="#fff" text-anchor="middle" dominant-baseline="middle" font-family="var(--font-sans)">{seat.parti}</text>
        </g>
      </g>
    )
  })}
  <style>.daf-seat{transition:opacity .12s}.daf-seat:hover{cursor:pointer}.daf-seat:hover circle{stroke:var(--color-text);stroke-width:2}</style>
</svg>
