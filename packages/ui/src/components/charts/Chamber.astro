---
/**
 * Chamber — SVG hemicycle parliament chart.
 * Algorithm: parliament-svg (juliuste/parliament-svg)
 */
import type { PartyCode, VotePosition } from '../../tokens/index.ts'

interface Seat {
  nummer: number
  politikerId: string
  namn: string
  parti: PartyCode
}

interface Vote {
  politikerId: string
  röst: VotePosition
}

interface Props {
  seats?: Seat[]
  totalSeats?: number
  mode?: 'overview' | 'vote'
  votes?: Vote[]
  class?: string
}

const { seats = [], totalSeats: totalProp, mode = 'overview', votes = [], class: className } = Astro.props
const N = totalProp ?? seats.length ?? 81

// Scale: parliament-svg uses r_seat = 0.4 * seatDistance.
// We want r_seat = 14, so R0 must be large enough.
// With R0=200, for 81 seats we get ~5 rings, seatDistance~35, r_seat=14 → perfect.
const R0 = 200

// --- Algorithm from parliament-svg ---
function seatDistance(n: number, rings: number, r: number) {
  return (Math.PI * rings * r) / (n - rings) / (1 + (Math.PI * (rings - 1) * rings / 2) / (n - rings))
}

function score(n: number, rings: number, r: number) {
  return Math.abs(seatDistance(n, rings, r) * rings / r - 5 / 7)
}

function calcRings(n: number, r: number) {
  let k = Math.floor(Math.log2(n)) || 1
  let d = score(n, k, r)
  let dir = 0
  if (score(n, k + 1, r) < d) dir = 1
  if (k > 1 && score(n, k - 1, r) < d) dir = -1
  while (k + dir > 0 && score(n, k + dir, r) < d) { d = score(n, k + dir, r); k += dir }
  return k
}

// Sainte-Laguë
function distribute(radii: number[], total: number) {
  const result = radii.map(() => 0)
  for (let s = 0; s < total; s++) {
    let best = 0
    for (let i = 1; i < radii.length; i++) {
      if (radii[i] / (2 * result[i] + 1) > radii[best] / (2 * result[best] + 1)) best = i
    }
    result[best]++
  }
  return result
}

const numRings = calcRings(N, R0)
const dist = seatDistance(N, numRings, R0)
const radii = Array.from({ length: numRings }, (_, i) => R0 - i * dist)
const perRing = distribute(radii, N)

// Generate positions
interface Pos { x: number; y: number }
const rings: Pos[][] = []
for (let i = 0; i < numRings; i++) {
  const r = radii[i]
  const count = perRing[i]
  const a = (Math.PI * r) / ((count - 1) || 1)
  const ring: Pos[] = []
  for (let j = 0; j < count; j++) {
    const b = j * a
    ring.push({ x: r * Math.cos(b / r - Math.PI), y: r * Math.sin(b / r - Math.PI) })
  }
  rings.push(ring)
}

// Round-robin fill (least-filled ring gets next seat)
const partyGroups = new Map<string, Seat[]>()
for (const s of seats) { const l = partyGroups.get(s.parti) ?? []; l.push(s); partyGroups.set(s.parti, l) }
const orderedSeats: Seat[] = [...partyGroups.entries()].sort((a, b) => b[1].length - a[1].length).flatMap(([_, m]) => m)

const progress = new Array(numRings).fill(0)
const points: { x: number; y: number; seat: Seat | null }[] = []

for (let i = 0; i < N; i++) {
  let best = 0
  for (let k = 1; k < numRings; k++) {
    if ((progress[k] / rings[k].length) < (progress[best] / rings[best].length)) best = k
  }
  const pos = rings[best][progress[best]]
  points.push({ ...pos, seat: orderedSeats[i] ?? null })
  progress[best]++
}

// ViewBox
const pad = dist * 0.5
const vbX = Math.min(...points.map(p => p.x)) - pad
const vbY = Math.min(...points.map(p => p.y)) - pad
const vbW = Math.max(...points.map(p => p.x)) - vbX + pad
const vbH = Math.max(...points.map(p => p.y)) - vbY + pad

const voteMap = new Map(votes.map(v => [v.politikerId, v.röst]))
// Party stats for hover
const partyStats = [...partyGroups.entries()]
  .sort((a, b) => b[1].length - a[1].length)
  .map(([parti, members]) => ({ parti, count: members.length, pct: Math.round(members.length / N * 100) }))
const partyStatsJson = JSON.stringify(partyStats)
---

<div class="daf-chamber" data-total={N} data-parties={partyStatsJson}>
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={`${vbX.toFixed(2)} ${vbY.toFixed(2)} ${vbW.toFixed(2)} ${vbH.toFixed(2)}`}
  role="img"
  aria-label={`Kommunfullmäktige — ${N} platser`}
  class:list={['chamber', className]}
>
  {points.map(({ x, y, seat }) => {
    const cls = mode === 'vote' && seat
      ? `vote ${voteMap.get(seat.politikerId) ?? ''}`
      : `seat parti-${(seat?.parti ?? '-').toLowerCase()}`
    return (
      <g class="daf-chamber__seat" data-parti={seat?.parti?.toLowerCase() ?? ''}>
        {seat && <title>{`${seat.namn} (${seat.parti})`}</title>}
        <circle cx={x.toFixed(3)} cy={y.toFixed(3)} r="14" class={cls} />
        {seat && <text x={x.toFixed(3)} y={(y + 1.5).toFixed(3)} class="inverse">{seat.parti.toUpperCase()}</text>}
      </g>
    )
  })}
  <text class="daf-chamber__center h2" x={(vbX + vbW / 2).toFixed(2)} y={(vbY + vbH - 10).toFixed(2)}>{N}</text>
</svg>
</div>

<style>
  .chamber { width: 100%; height: auto; display: block; }
  .daf-chamber__seat { transition: opacity 0.2s; cursor: pointer; }
  .daf-chamber__seat.dimmed { opacity: 0.2; }
</style>

<script is:inline>
  document.querySelectorAll('.daf-chamber').forEach(el => {
    const total = el.dataset.total
    const parties = JSON.parse(el.dataset.parties || '[]')
    const seatEls = el.querySelectorAll('.daf-chamber__seat')
    const centerEl = el.querySelector('.daf-chamber__center')

    function highlight(parti) {
      seatEls.forEach(s => s.classList.toggle('dimmed', s.dataset.parti !== parti))
      const p = parties.find(x => x.parti.toLowerCase() === parti)
      if (centerEl && p) centerEl.textContent = p.count + ' (' + p.pct + '%)'
    }

    function reset() {
      seatEls.forEach(s => s.classList.remove('dimmed'))
      if (centerEl) centerEl.textContent = total
    }

    seatEls.forEach(s => {
      s.addEventListener('mouseenter', () => highlight(s.dataset.parti))
      s.addEventListener('mouseleave', reset)
    })
  })
</script>
