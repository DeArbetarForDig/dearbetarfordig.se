  [55, 530, 560],
  [56, 670, 560],
  [57, 740, 550],
  [58, 810, 530],
  [59, 880, 510],
  [60, 950, 480],
  [61, 1020, 450],
  [62, 1090, 410],
  [63, 1150, 360],
  [64, 1180, 310],
