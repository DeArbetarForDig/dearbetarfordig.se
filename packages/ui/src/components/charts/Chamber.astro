---
interface Seat {
  nummer: number
  politikerId: string
  namn: string
  parti: string
}

interface Vote {
  politikerId: string
  rost: 'ja' | 'nej' | 'avstar' | 'franvarande'
}

interface Props {
  seats: Seat[]
  mode?: 'overview' | 'vote'
  votes?: Vote[]
  class?: string
}

const { seats = [], mode = 'overview', votes = [], class: className } = Astro.props

const SEAT_POS: [number, number, number][] = [
  [1, 600, 0],
  [2, 520, 20],
  [3, 450, 20],
  [4, 380, 20],
  [5, 390, 190],
  [6, 460, 230],
  [7, 530, 260],
