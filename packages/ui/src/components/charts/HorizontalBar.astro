---
/**
 * HorizontalBar — horizontal bar chart for comparing categories.
 *
 * Features:
 * - Color thresholds (moreThan/lessThan → red/green)
 * - Custom bar height
 * - Labels on left, values on right
 * - Optional unit label
 * - Hover highlight (dims others)
 */
interface Bar {
  label: string
  value: number
  color?: string
  subtitle?: string
}

interface Threshold {
  moreThan?: number
  lessThan?: number
  color: string
}

interface Props {
  bars: Bar[]
  unit?: string
  barHeight?: number
  labelWidth?: string
  min?: number
  max?: number
  thresholds?: Threshold[]
  class?: string
}

const { bars = [], unit = '', barHeight = 16, labelWidth = '10rem', min: minProp = 0, max: maxProp, thresholds = [], class: className } = Astro.props
const max = maxProp ?? Math.max(...bars.map(b => b.value), 1)
const min = minProp

function getBarColor(bar: Bar, value: number): string {
  if (bar.color) return bar.color
  for (const t of thresholds) {
    if (t.moreThan != null && value > t.moreThan) return `var(--color-${t.color === 'red' ? 'negative' : t.color === 'green' ? 'positive' : 'primary'})`
    if (t.lessThan != null && value < t.lessThan) return `var(--color-${t.color === 'red' ? 'negative' : t.color === 'green' ? 'positive' : 'primary'})`
  }
  return 'var(--color-primary)'
}
---
<div class:list={['daf-hbar grid gap-2', className]}>
  {bars.map(bar => {
    const pct = (max - min) > 0 ? ((bar.value - min) / (max - min)) * 100 : 0
    const color = getBarColor(bar, bar.value)
    return (
      <div class="daf-hbar__row flex items-center gap-3">
        <span class="text-sm font-semibold shrink-0 text-left" style={`width:${labelWidth}`}>{bar.label}</span>
        {bar.subtitle && <span class="text-xs font-mono text-[var(--color-text-muted)] shrink-0 text-right" style="width:2rem">{bar.subtitle}</span>}
        <div class="flex-1 rounded-full overflow-hidden bg-[var(--color-surface-sunken)]" style={`height:${barHeight}px`}>
          <div class="daf-hbar__fill rounded-full transition-all duration-300" style={`width:${pct}%;height:${barHeight}px;background:${color}`} />
        </div>
        <span class="font-mono text-sm shrink-0 text-right" style="width:3.5rem">{bar.value}{unit && <span class="text-xs text-[var(--color-text-muted)] ml-0.5">{unit}</span>}</span>
      </div>
    )
  })}
</div>

<style>
  .daf-hbar__row {
    transition: opacity 0.2s;
  }
  .daf-hbar:hover .daf-hbar__row {
    opacity: 0.4;
  }
  .daf-hbar:hover .daf-hbar__row:hover {
    opacity: 1;
  }
</style>
