---
/**
 * Donut — circular chart showing proportional data.
 *
 * Behavior:
 * - Hover: active segment full opacity, others dim to 0.2; center shows value + label
 * - No hover: center shows total + unit (if showValue)
 * - showAbsoluteValue: numbers instead of percentages on hover
 * - Segments expand on hover (stroke-width change)
 */
interface Segment {
  label: string
  value: number
  color: string
}

interface Props {
  segments: Segment[]
  size?: number
  thickness?: number
  showValue?: boolean
  showAbsoluteValue?: boolean
  unit?: string
  legend?: boolean
  class?: string
}

const {
  segments = [],
  size = 200,
  thickness = 34,
  showValue = false,
  showAbsoluteValue = false,
  unit = '',
  legend = true,
  class: className,
} = Astro.props

const total = segments.reduce((s, x) => s + x.value, 0) || 1
const r = size / 2 - thickness / 2 - 2
const cx = size / 2
const cy = size / 2
const circ = 2 * Math.PI * r

let offset = 0
const arcs = segments.map((seg) => {
  const frac = seg.value / total
  const dash = frac * circ
  const arc = { ...seg, frac, dash, offset }
  offset += dash
  return arc
})

const dataJson = JSON.stringify(
  arcs.map((a) => ({ label: a.label, value: a.value, pct: Math.round(a.frac * 100) })),
)
---
<div
  class:list={['daf-donut flex items-center gap-6', className]}
  data-segments={dataJson}
  data-total={total}
  data-unit={unit}
  data-show-value={showValue ? 'true' : ''}
  data-show-absolute={showAbsoluteValue ? 'true' : ''}
>
  <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} role="img" aria-label="Fördelning" class="shrink-0">
    <g class="daf-donut__ring" transform={`rotate(-90 ${cx} ${cy})`}>
      {arcs.map((a, i) => (
        <circle
          class="daf-donut__segment"
          data-index={i}
          cx={cx} cy={cy} r={r} fill="none"
          stroke={a.color} stroke-width={thickness}
          stroke-dasharray={`${a.dash} ${circ - a.dash}`}
          stroke-dashoffset={-a.offset}
        />
      ))}
    </g>
    <g class="daf-donut__center">
      <text class="daf-donut__value" x={cx} y={cy - (unit ? 4 : 0)} text-anchor="middle" dominant-baseline="central"
        style={`font-family:var(--font-mono);font-weight:700;font-size:${size * 0.11}px;fill:var(--color-text)`}>
        {showValue ? total : ''}
      </text>
      <text class="daf-donut__unit" x={cx} y={cy + size * 0.09} text-anchor="middle" dominant-baseline="central"
        style={`font-family:var(--font-sans);font-size:${size * 0.06}px;fill:var(--color-text-muted)`}>
        {showValue ? unit : ''}
      </text>
      <text class="daf-donut__label" x={cx} y={cy + size * 0.17} text-anchor="middle" dominant-baseline="central"
        style={`font-family:var(--font-sans);font-size:${size * 0.04}px;fill:var(--color-text-muted)`}>
      </text>
    </g>
  </svg>
  {legend && (
    <ul class="daf-donut__legend list-none m-0 p-0 grid gap-1.5">
      {arcs.map((a, i) => (
        <li class="flex items-center gap-2 text-sm" data-index={i}>
          <span class="w-3 h-3 rounded-sm shrink-0" style={`background:${a.color}`} />
          <span class="text-(--color-text)">{a.label}</span>
          <span class="font-mono text-(--color-text-muted) ml-auto pl-3">
            {showAbsoluteValue ? `${a.value} ${unit}` : `${Math.round(a.frac * 100)}%`}
          </span>
          {showAbsoluteValue && <span class="font-mono text-(--color-text-subtle) pl-2 w-10 text-right">{Math.round(a.frac * 100)}%</span>}
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  .daf-donut__segment {
    transition: opacity 0.3s, stroke-width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }
  .daf-donut__segment.dimmed {
    opacity: 0.2;
  }
  .daf-donut__segment.active {
    stroke-width: calc(attr(stroke-width) + 6);
  }
  .daf-donut__legend li {
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .daf-donut__legend li.dimmed {
    opacity: 0.3;
  }
</style>

<script is:inline>
  document.querySelectorAll('.daf-donut').forEach(donut => {
    const segments = JSON.parse(donut.dataset.segments || '[]')
    const total = donut.dataset.total
    const unit = donut.dataset.unit || ''
    const showValue = donut.dataset.showValue === 'true'
    const showAbsolute = donut.dataset.showAbsolute === 'true'
    const circles = donut.querySelectorAll('.daf-donut__segment')
    const legendItems = donut.querySelectorAll('.daf-donut__legend li')
    const valueEl = donut.querySelector('.daf-donut__value')
    const unitEl = donut.querySelector('.daf-donut__unit')
    const labelEl = donut.querySelector('.daf-donut__label')
    const baseWidth = circles[0] ? parseFloat(circles[0].getAttribute('stroke-width')) : 34

    function highlight(index) {
      circles.forEach((c, i) => {
        c.classList.toggle('dimmed', i !== index)
        c.style.strokeWidth = i === index ? (baseWidth + 6) + 'px' : (baseWidth - 2) + 'px'
      })
      legendItems.forEach((li, i) => li.classList.toggle('dimmed', i !== index))
      const seg = segments[index]
      if (valueEl) valueEl.textContent = showAbsolute ? seg.value : seg.pct + '%'
      if (unitEl) unitEl.textContent = showAbsolute ? unit : ''
      if (labelEl) labelEl.textContent = seg.label.length > 25 ? seg.label.slice(0, 23) + '…' : seg.label
    }

    function reset() {
      circles.forEach(c => {
        c.classList.remove('dimmed')
        c.style.strokeWidth = baseWidth + 'px'
      })
      legendItems.forEach(li => li.classList.remove('dimmed'))
      if (valueEl) valueEl.textContent = showValue ? total : ''
      if (unitEl) unitEl.textContent = showValue ? unit : ''
      if (labelEl) labelEl.textContent = ''
    }

    circles.forEach((c, i) => {
      c.addEventListener('mouseenter', (e) => highlight(i))
      c.addEventListener('mousemove', (e) => {
        if (window.dafChartTooltip) {
          const seg = segments[i]
          window.dafChartTooltip.show(e, {
            title: seg.label,
            items: [{ label: showAbsolute ? 'Värde' : 'Andel', value: showAbsolute ? seg.value : seg.pct + '%' }]
          })
        }
      })
      c.addEventListener('mouseleave', () => {
        reset()
        if (window.dafChartTooltip) window.dafChartTooltip.hide()
      })
    })
    legendItems.forEach((li, i) => {
      li.addEventListener('mouseenter', () => highlight(i))
      li.addEventListener('mouseleave', () => {
        reset()
        if (window.dafChartTooltip) window.dafChartTooltip.hide()
      })
    })
  })
</script>
