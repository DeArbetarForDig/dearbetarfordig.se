---
/**
 * Donut-compliant circular chart showing proportional data as segments.
 *
 * Behavior (from docs/reference/design/library/data-visualization/donut.md):
 * - Show parts of a whole (2–8 segments ideal)
 * - Variants: default (% on hover), with total (center value + unit), absolute values
 * - Legend with color swatch + label + value
 * - Hover: segment expands slightly, tooltip shows name + value/percentage
 * - Click: optional onSelect (client-side)
 */
interface Segment {
  label: string
  value: number
  color: string
}

interface Props {
  segments: Segment[]
  size?: number
  thickness?: number
  showValue?: boolean
  showAbsoluteValue?: boolean
  unit?: string
  legend?: boolean
  class?: string
}

const {
  segments = [],
  size = 200,
  thickness = 34,
  showValue = false,
  showAbsoluteValue = false,
  unit = '',
  legend = true,
  class: className,
} = Astro.props

const total = segments.reduce((s, x) => s + x.value, 0) || 1
const r = size / 2 - thickness / 2 - 2
const cx = size / 2
const cy = size / 2
const circ = 2 * Math.PI * r

let offset = 0
const arcs = segments.map((seg) => {
  const frac = seg.value / total
  const dash = frac * circ
  const arc = { ...seg, frac, dash, offset }
  offset += dash
  return arc
})
---
<div class:list={['daf-donut flex items-center gap-6', className]}>
  <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} role="img" aria-label="Fördelning" class="shrink-0">
    <g transform={`rotate(-90 ${cx} ${cy})`}>
      {arcs.map((a, i) => (
        <circle
          class="daf-donut__segment"
          data-index={i}
          cx={cx} cy={cy} r={r} fill="none"
          stroke={a.color} stroke-width={thickness}
          stroke-dasharray={`${a.dash} ${circ - a.dash}`}
          stroke-dashoffset={-a.offset}
        >
          <title>{a.label}: {showAbsoluteValue ? a.value : `${Math.round(a.frac * 100)}%`}</title>
        </circle>
      ))}
    </g>
    {showValue && (
      <text x={cx} y={cy - (unit ? 4 : 0)} text-anchor="middle" dominant-baseline="central"
        style={`font-family:var(--font-mono);font-weight:700;font-size:${size * 0.16}px;fill:var(--color-text)`}>
        {total}
      </text>
    )}
    {showValue && unit && (
      <text x={cx} y={cy + size * 0.12} text-anchor="middle" dominant-baseline="central"
        style={`font-family:var(--font-sans);font-size:${size * 0.07}px;fill:var(--color-text-muted)`}>
        {unit}
      </text>
    )}
  </svg>
  {legend && (
    <ul class="list-none m-0 p-0 grid gap-1.5">
      {arcs.map(a => (
        <li class="flex items-center gap-2 text-sm">
          <span class="w-3 h-3 rounded-sm shrink-0" style={`background:${a.color}`} />
          <span class="text-(--color-text)">{a.label}</span>
          <span class="font-mono text-(--color-text-muted) ml-auto pl-3">
            {showAbsoluteValue ? a.value : `${Math.round(a.frac * 100)}%`}
          </span>
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  .daf-donut__segment {
    transition: stroke-width 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }
  .daf-donut__segment:hover {
    stroke-width: calc(var(--thickness, 34px) + 4px);
  }
</style>
