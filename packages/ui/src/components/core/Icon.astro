---
/**
 * Icon — renders Lucide icons from the lucide-static package.
 *
 * Usage:
 *   <Icon name="triangle-alert" size={20} />
 *   <Icon name="circle-check" size={14} class="text-green-500" />
 *
 * Props:
 * - name: Lucide icon name in kebab-case (e.g., "shield-alert", "arrow-right")
 * - size: pixel size (default 20)
 * - class: additional CSS classes
 *
 * Icons are inlined as SVG at build time (no client-side JS or network requests).
 * Color inherits from parent via currentColor.
 * Full icon list: https://lucide.dev/icons
 */
interface Props {
  name: string
  size?: number
  class?: string
}

const { name, size = 20, class: className } = Astro.props
const icons = await import('lucide-static')
// lucide-static exports PascalCase names (e.g., 'ArrowRight', 'MapPin')
const key = name
  .split('-')
  .map((s) => s[0].toUpperCase() + s.slice(1))
  .join('')
const svg = ((icons as any)[key] || '') as string
const sized = svg
  .replace(/width="24"/, `width="${size}"`)
  .replace(/height="24"/, `height="${size}"`)
---
<span class:list={['inline-flex items-center justify-center shrink-0', className]} set:html={sized} />
