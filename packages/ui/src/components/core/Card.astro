---
/**
 * Card — container for short related information.
 * Structure: header (title + subtitle + optional tooltip) + content (slot).
 */
import Tooltip from './Tooltip.astro'

interface Props {
  title?: string
  subtitle?: string
  tooltip?: string
  tooltipPosition?: 'top' | 'top-end' | 'bottom' | 'bottom-end' | 'left' | 'right'
  titleSize?: 'sm' | 'base' | 'lg'
  class?: string
}

const {
  title,
  subtitle,
  tooltip,
  tooltipPosition = 'top-end',
  titleSize = 'base',
  class: className,
} = Astro.props
const titleClasses = {
  sm: 'text-sm text-[var(--color-text-muted)]',
  base: 'font-bold text-[var(--color-text)]',
  lg: 'text-lg font-bold text-[var(--color-text)]',
}
---
<div class:list={['card bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4 shadow-[var(--shadow-sm)] transition-shadow duration-150', className]}>
  {(title || subtitle) && (
    <div class="card__header mb-3">
      {title && !tooltip && <div class={titleClasses[titleSize]}>{title}</div>}
      {title && tooltip && (
        <Tooltip text={tooltip} position={tooltipPosition}>
          <div class:list={[titleClasses[titleSize], 'cursor-help inline-block']} style="text-decoration: underline dotted var(--color-text-subtle); text-underline-offset: 3px">{title}</div>
        </Tooltip>
      )}
      {subtitle && <div class="text-xs text-[var(--color-text-subtle)] mt-0.5">{subtitle}</div>}
    </div>
  )}
  <slot />
</div>
