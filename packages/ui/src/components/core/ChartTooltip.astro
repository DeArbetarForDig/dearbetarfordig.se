---
/**
 * ChartTooltip — mouse-following tooltip for data visualizations.
 *
 * Styled via chart-tooltip.css (imported in global.css).
 * Charts call window.dafChartTooltip.show(event, data) / .hide()
 */
interface Props {
  class?: string
}

const { class: className } = Astro.props
---
<div class:list={['chart-tooltip', className]} aria-hidden="true">
  <div class="content">
    <div class="title">
      <span class="unit-title"></span>
      <span class="unit-value"></span>
    </div>
    <div class="items"></div>
  </div>
</div>

<script is:inline>
  /**
   * Global chart tooltip controller.
   * Charts call dafChartTooltip.show(event, data) and .hide().
   */
  window.dafChartTooltip = (() => {
    const el = document.querySelector('.chart-tooltip')
    if (!el) return { show() {}, hide() {} }

    const titleEl = el.querySelector('.unit-title')
    const unitEl = el.querySelector('.unit-value')
    const itemsEl = el.querySelector('.items')
    const offset = 16

    return {
      /**
       * Show tooltip near cursor.
       * @param {MouseEvent} event - for positioning
       * @param {Object} data - { title, unit?, items: [{label, value, color?}] }
       */
      show(event, data) {
        if (titleEl) titleEl.textContent = data.title || ''
        if (unitEl) unitEl.textContent = data.unit || ''
        if (itemsEl) {
          itemsEl.innerHTML = (data.items || []).map(item =>
            `<div class="item">` +
            (item.color ? `<span class="dot" style="background:${item.color}"></span>` : '') +
            `<span class="key">${item.label}</span>` +
            `<span class="value">${item.value}</span>` +
            `</div>`
          ).join('')
        }

        const x = event.clientX
        const y = event.clientY
        const w = el.offsetWidth
        const h = el.offsetHeight

        el.style.left = (x + w + offset * 2 > window.innerWidth ? x - w - offset : x + offset) + 'px'
        el.style.top = (y + h + offset > window.innerHeight ? y - h - offset / 2 : y + offset) + 'px'
        el.classList.add('visible')
      },

      hide() {
        el.classList.remove('visible')
      }
    }
  })()
</script>
