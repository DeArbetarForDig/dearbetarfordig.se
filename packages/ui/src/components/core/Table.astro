---
/**
 * Table — structured data display with headers, rows, and columns.
 *
 * Cells can be:
 * - plain string/number
 * - { text, color } for colored dot indicator
 * - { text, href } for links
 * - { text, color, href } for colored link
 */
interface Props {
  headers: string[]
  rows: (string | number | { text: string; color?: string; href?: string })[][]
  variant?: 'default' | 'compact' | 'striped'
  alignRight?: number[]
  class?: string
}

const { headers, rows, variant = 'default', alignRight = [], class: className } = Astro.props
---
<div class:list={['table-wrapper', className]}>
  <table class:list={['daf-table', variant !== 'default' && `daf-table--${variant}`]}>
    <thead>
      <tr>
        {headers.map((h, i) => (
          <th class:list={[alignRight.includes(i) && 'right']}>{h}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map(row => (
        <tr>
          {row.map((cell, i) => (
            <td class:list={[alignRight.includes(i) && 'right']}>
              {typeof cell === 'object' && cell !== null && 'color' in cell && !('href' in cell) ? (
                <span class="daf-table__cell-icon">
                  <span class="daf-table__dot" style={`--dot-color:${(cell as any).color}`} />
                  {(cell as any).text}
                </span>
              ) : typeof cell === 'object' && cell !== null && 'href' in cell ? (
                <a href={(cell as any).href} class="daf-table__link">
                  {'color' in cell && <span class="daf-table__dot" style={`--dot-color:${(cell as any).color}`} />}
                  {(cell as any).text}
                </a>
              ) : cell}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .table-wrapper {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
  }

  .daf-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: var(--font-size-label);
  }

  .daf-table th {
    border-bottom: 1px solid var(--color-border-strong);
    font-weight: 500;
    padding: var(--space-md);
    color: var(--color-text);
    white-space: nowrap;
  }

  .daf-table td {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-md);
    color: var(--color-text);
  }

  .daf-table td:first-child {
    white-space: nowrap;
  }

  .daf-table tr:last-child td {
    border-bottom: none;
  }

  .daf-table tbody tr:hover {
    background-color: var(--color-surface-sunken);
  }

  /* Right alignment for numeric columns */
  .daf-table .right {
    text-align: right;
    white-space: nowrap;
  }

  /* Cell with color dot indicator */
  .daf-table__cell-icon {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .daf-table__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--dot-color);
  }

  .daf-table__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-primary);
    text-decoration: none;
  }

  .daf-table__link:hover {
    color: var(--color-primary-hover);
  }

  /* Compact variant */
  .daf-table--compact th,
  .daf-table--compact td {
    padding: var(--space-sm) var(--space-md);
  }

  /* Striped variant */
  .daf-table--striped tbody tr:nth-child(even) {
    background-color: var(--color-surface-sunken);
  }

  .daf-table--striped tbody tr:hover {
    background-color: var(--color-surface-sunken);
    filter: brightness(0.97);
  }
</style>
