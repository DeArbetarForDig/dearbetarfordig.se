---
/**
 * PoliticianCard — compact card for a politician in list views.
 *
 * Usage:
 *   <PoliticianCard namn="Anna Svensson" parti="C" roll="Ledamot" url="/politiker/123" />
 *
 * Wraps the core Card component for consistent styling.
 */
import Card from '../core/Card.astro'
import Icon from '../core/Icon.astro'
import PartyTag from '../core/PartyTag.astro'

interface Props {
  namn: string
  parti: string
  foto?: string
  roll?: string
  narvaro?: number
  url?: string
  class?: string
}

const { namn, parti, foto, roll, narvaro, url = '#', class: className } = Astro.props
---
<a href={url} class:list={['politician-card block no-underline', className]}>
  <Card>
    <div class="flex gap-4 items-start">
      {foto ? (
        <img src={foto} alt="" width="56" height="56" class="w-14 h-14 rounded-lg object-cover shrink-0" loading="lazy" />
      ) : (
        <span class="w-14 h-14 shrink-0 rounded-lg bg-[var(--color-surface-sunken)] flex items-center justify-center">
          <Icon name="user" size={26} class="text-[var(--color-text-subtle)]" />
        </span>
      )}
      <div style="min-width:0;flex:1">
        <div class="flex items-center gap-2 mb-0.5" style="overflow:hidden">
          <PartyTag parti={parti} size="sm" />
          <span class="text-base font-semibold leading-tight" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{namn}</span>
        </div>
        {roll && <p class="m-0 text-sm text-[var(--color-text-muted)]">{roll}</p>}
        {narvaro != null && (
          <p class="m-0 mt-1 text-sm text-[var(--color-text-muted)]">
            Närvaro: <span class="font-mono font-semibold text-[var(--color-text)]">{narvaro}%</span>
          </p>
        )}
      </div>
    </div>
  </Card>
</a>

<style is:global>
  .politician-card:hover .card {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-strong);
    transform: translateY(-1px);
  }
  .politician-card .card {
    transition: box-shadow 150ms, border-color 150ms, transform 150ms;
  }
</style>
