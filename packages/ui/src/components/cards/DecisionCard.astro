---
/**
 * DecisionCard — displays a single KF decision in a feed.
 *
 * Wraps the core Card component for consistent styling and hover.
 */
import Card from '../core/Card.astro'
import Icon from '../core/Icon.astro'
import StatusBadge from '../core/StatusBadge.astro'

interface Props {
  titel: string
  datum: string
  status?: string
  paragraf?: string
  ja?: number
  nej?: number
  avstar?: number
  namnupprop?: boolean
  url?: string
  class?: string
}

const {
  titel,
  datum,
  status = 'bifall',
  paragraf,
  ja,
  nej,
  avstar = 0,
  namnupprop = false,
  url = '#',
  class: className,
} = Astro.props
const hasVotes = ja != null && nej != null
const total = hasVotes ? ja + nej + avstar : 0
const jaPct = total ? Math.round((ja! / total) * 100) : 0
const nejPct = total ? Math.round((nej! / total) * 100) : 0
---
<a href={url} class:list={['block h-full', className]}>
  <Card class="h-full flex flex-col">
    <div class="flex justify-between items-center mb-2">
      <StatusBadge status={status} />
      <span class="flex items-center gap-2 text-[var(--color-text-muted)]">
        {paragraf && <span>{paragraf}</span>}
        <time datetime={datum}>{datum}</time>
      </span>
    </div>
    <h3 class="text-base font-semibold m-0 mb-1 leading-snug text-[var(--color-text)]">{titel}</h3>
    {hasVotes && (
      <div class="mt-auto pt-2">
        <div class="flex gap-4 text-sm text-[var(--color-text-muted)] mb-1.5">
          <span>Ja: <strong class="font-mono" style="color:var(--vote-ja)">{ja}</strong></span>
          <span>Nej: <strong class="font-mono" style="color:var(--vote-nej)">{nej}</strong></span>
          <span>Avstår: <strong class="font-mono" style="color:var(--vote-avstår)">{avstar}</strong></span>
          {namnupprop ? (
            <span class="ml-auto flex items-center gap-1 text-xs text-[var(--color-positive)]"><Icon name="user-check" size={12} /> Namnupprop</span>
          ) : (
            <span class="ml-auto flex items-center gap-1 text-xs text-[var(--color-text-subtle)]"><Icon name="hand" size={12} /> Handuppräckning</span>
          )}
        </div>
        <div class="flex h-2 rounded-full overflow-hidden bg-[var(--color-surface-sunken)]" title={`${jaPct}% ja`}>
          <span style={`width:${jaPct}%;background:var(--vote-ja)`}></span>
          <span style={`width:${nejPct}%;background:var(--vote-nej)`}></span>
          <span class="flex-1" style="background:var(--vote-avstår)"></span>
        </div>
      </div>
    )}
  </Card>
</a>
