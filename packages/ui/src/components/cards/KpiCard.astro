---
/**
 * KpiCard — Key Performance Indicator card.
 *
 * Usage:
 *   <KpiCard label="Röster" value={1234} />
 *   <KpiCard label="Budget" value="10 226" unit="mnkr" />
 *   <KpiCard label="Resultat" value="+73" unit="mnkr" color="var(--color-positive)" />
 *
 * Wraps the core Card component for consistent styling.
 */
import Card from '../core/Card.astro'

interface Props {
  label: string
  value: string | number
  unit?: string
  color?: string
  class?: string
}

const { label, value, unit, color, class: className } = Astro.props
---
<div class:list={[className]}>
  <Card title={label} titleSize="sm">
    <div class:list={['font-mono text-2xl font-bold', color && 'text-(--kpi-color)']} style={color ? `--kpi-color:${color}` : ''}>
      {value}{unit && <span class="text-sm text-[var(--color-text-muted)]"> {unit}</span>}
    </div>
  </Card>
</div>
