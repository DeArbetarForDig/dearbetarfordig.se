---
import Card from '../../../../../ui/src/components/core/Card.astro'
import Pill from '../../../../../ui/src/components/core/Pill.astro'
import { getFörvaltningar } from '../../../data/api'
import Kommun from '../../../layouts/Kommun.astro'

const förvaltningar = await getFörvaltningar()

// Sort by salary descending
const sorted = förvaltningar.sort(
  (a: any, b: any) => (b.direktör?.lön || 0) - (a.direktör?.lön || 0),
)
---

<Kommun title="Förvaltningar — Göteborg">
  <h1 class="text-[2rem] font-bold mb-2">Förvaltningar</h1>
  <p class="text-sm text-[var(--color-text-muted)] mb-6">{sorted.length} förvaltningar · Löner per 2026-04-01 · Utfall 2025</p>

  <div class="grid gap-4">
    {sorted.map((f: any) => {
      const d = f.direktör
      const resultat = f.utfall?.resultatMnkr ?? null
      const budget = f.utfall?.kommunbidragMnkr ?? f.nämnd?.kommunbidragMnkr ?? null
      const hasRevision = f.revision?.typ === 'anmärkning'
      const resultatLabel = resultat !== null
        ? resultat > 0
          ? `Överskott ${resultat} mnkr`
          : resultat < 0
            ? `Underskott ${Math.abs(resultat)} mnkr`
            : 'Nollresultat'
        : null
      return (
        <a href={`/goteborg/forvaltning/${f.id}`} class="block">
          <Card>
            <div class="flex items-center justify-between gap-4 flex-wrap">
              <div class="min-w-0">
                <p class="font-semibold text-base truncate">{d.förvaltning}</p>
                <p class="text-sm text-[var(--color-text-muted)]">
                  Direktör: {d.namn} · {d.lön?.toLocaleString('sv-SE')} kr/mån
                </p>
                <p class="text-xs text-[var(--color-text-muted)] mt-0.5">
                  {budget ? `Budget: ${budget.toLocaleString('sv-SE')} mnkr` : ''}
                  {budget && resultatLabel ? ' · ' : ''}
                  {resultatLabel && (
                    <span class={resultat < 0 ? 'text-[var(--color-error)] font-semibold' : 'text-[var(--color-success)]'}>
                      Utfall 2025: {resultatLabel}
                    </span>
                  )}
                </p>
              </div>
              <div class="shrink-0">
                {hasRevision ? (
                  <Pill severity="warning">Anmärkning</Pill>
                ) : (
                  <Pill severity="success">Godkänd revision</Pill>
                )}
              </div>
            </div>
          </Card>
        </a>
      )
    })}
  </div>
</Kommun>
