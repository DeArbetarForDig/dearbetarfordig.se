---
import DecisionCard from '../../../../ui/src/components/cards/DecisionCard.astro'
import KpiCard from '../../../../ui/src/components/cards/KpiCard.astro'
import Chamber from '../../../../ui/src/components/charts/Chamber.astro'
import Donut from '../../../../ui/src/components/charts/Donut.astro'
import Button from '../../../../ui/src/components/core/Button.astro'
import Icon from '../../../../ui/src/components/core/Icon.astro'
import { getBeslut, getMetrics, getPolitiker, getStats } from '../../data/api'
import Base from '../../layouts/Base.astro'

const stats = await getStats()
const metrics = await getMetrics()
const politiker = await getPolitiker()
const beslutList = await getBeslut(200)

const seats = politiker
  .slice(0, 81)
  .map((p, i) => ({ nummer: i + 1, politikerId: p.id, namn: p.namn, parti: p.parti }))

const kpis = [
  { value: String(stats.politiker), label: 'Politiker' },
  { value: String(metrics.beslutskraft.totalt), label: 'Beslut' },
  {
    value: String(metrics.konsensus.konsensusgradProcent),
    unit: '%',
    label: 'Utan votering',
    trend: 'up' as const,
    trendValue: 'konsensus',
  },
  {
    value: String(Math.round((metrics.beslutskraft.bifall / metrics.beslutskraft.totalt) * 100)),
    unit: '%',
    label: 'Bifallsgrad',
  },
]

const partiMandat = Object.entries(stats.partier).map(([label, value]) => ({
  label,
  value,
  color: `var(--parti-${label.toLowerCase()})`,
}))

const senasteBeslut = beslutList
  .filter((b) => b.beslut)
  .slice(0, 6)
  .map((b) => ({
    titel: b.rubrik.replace(/^§ \d+ /, ''),
    datum: b.datum,
    status: b.beslut === 'bordläggning' ? 'bordlagd' : b.beslut,
    paragraf: b.paragraf ? `KF ${b.paragraf}` : undefined,
    ja: b.votering?.ja,
    nej: b.votering?.nej,
    avstar: b.votering?.avstår,
    url: `/goteborg/beslut/${encodeURIComponent(b.id)}`,
  }))
---

<Base title="Göteborg">

  <!-- Header -->
  <section class="mb-12">
    <h1 class="text-4xl font-bold mb-2">Göteborg</h1>
    <p class="text-[var(--color-text-muted)]">Kommunfullmäktige — 81 ledamöter som beslutar för dig</p>
  </section>

  <!-- Chamber -->
  <section class="mb-12">
    <div class="max-w-3xl mx-auto p-6 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)]">
      <Chamber seats={seats} mode="overview" />
    </div>
  </section>

  <!-- KPI row -->
  <section class="mb-12">
    <div class="grid gap-4" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
      {kpis.map(kpi => (
        <KpiCard value={kpi.value} unit={kpi.unit} label={kpi.label} trend={kpi.trend} trendValue={kpi.trendValue} />
      ))}
    </div>
  </section>

  <!-- Two-column: Donut + Struktur -->
  <section class="mb-12 grid gap-8 md:grid-cols-2">
    <!-- Mandatfördelning -->
    <div>
      <h2 class="text-2xl font-bold mb-4">Mandatfördelning</h2>
      <Donut segments={partiMandat} showLegend />
    </div>

    <!-- Struktur -->
    <div>
      <h2 class="text-2xl font-bold mb-4">Hur styrs Göteborg?</h2>
      <div class="flex flex-col gap-3">
        <div class="p-4 rounded-lg bg-[var(--color-surface)] border-l-4 border-l-[var(--color-primary)]">
          <h3 class="font-bold">Kommunfullmäktige (KF)</h3>
          <p class="text-sm text-[var(--color-text-muted)]">"Riksdagen för Göteborg" — 81 ledamöter fattar alla stora beslut</p>
        </div>
        <div class="ml-6 p-4 rounded-lg bg-[var(--color-surface)] border-l-4 border-l-violet-500">
          <h3 class="font-bold">Kommunstyrelsen (KS)</h3>
          <p class="text-sm text-[var(--color-text-muted)]">"Regeringen" — 13 ledamöter leder det dagliga arbetet</p>
        </div>
        <div class="ml-12 grid gap-2" style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));">
          <div class="p-2 px-3 rounded bg-[var(--color-surface-sunken)] text-sm">
            <span class="font-semibold">Grundskolenämnden</span><br/>
            <span class="text-xs text-[var(--color-text-muted)]">Skolor & lärare</span>
          </div>
          <div class="p-2 px-3 rounded bg-[var(--color-surface-sunken)] text-sm">
            <span class="font-semibold">Byggnadsnämnden</span><br/>
            <span class="text-xs text-[var(--color-text-muted)]">Vad som får byggas</span>
          </div>
          <div class="p-2 px-3 rounded bg-[var(--color-surface-sunken)] text-sm">
            <span class="font-semibold">Trafiknämnden</span><br/>
            <span class="text-xs text-[var(--color-text-muted)]">Vägar & spårvagnar</span>
          </div>
          <div class="p-2 px-3 rounded bg-[var(--color-surface-sunken)] text-sm">
            <span class="font-semibold">Socialnämnden</span><br/>
            <span class="text-xs text-[var(--color-text-muted)]">Stöd & omsorg</span>
          </div>
          <div class="p-2 px-3 rounded bg-[var(--color-surface-sunken)] text-sm">
            <span class="font-semibold">Miljönämnden</span><br/>
            <span class="text-xs text-[var(--color-text-muted)]">Klimat & natur</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Decision feed -->
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold">Senaste beslut</h2>
      <Button variant="ghost" href="/goteborg/beslut">Alla beslut →</Button>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {senasteBeslut.map(b => (
        <DecisionCard
          titel={b.titel}
          datum={b.datum}
          status={b.status}
          paragraf={b.paragraf}
          ja={b.ja}
          nej={b.nej}
          avstar={b.avstar}
          url={b.url}
        />
      ))}
    </div>
  </section>

</Base>
