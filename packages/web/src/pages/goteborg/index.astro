---
import DecisionCard from '../../../../ui/src/components/cards/DecisionCard.astro'
import KpiTrend from '../../../../ui/src/components/cards/KpiTrend.astro'
import OrgBlock from '../../../../ui/src/components/cards/OrgBlock.astro'
import Chamber from '../../../../ui/src/components/charts/Chamber.astro'
import Donut from '../../../../ui/src/components/charts/Donut.astro'
import Gauge from '../../../../ui/src/components/charts/Gauge.astro'
import Heatmap from '../../../../ui/src/components/charts/Heatmap.astro'
import HorizontalBar from '../../../../ui/src/components/charts/HorizontalBar.astro'
import Button from '../../../../ui/src/components/core/Button.astro'
import Card from '../../../../ui/src/components/core/Card.astro'
import Icon from '../../../../ui/src/components/core/Icon.astro'
import { fetchApi, getBeslut, getBudget, getMetrics, getPolitiker, getStats } from '../../data/api'
import Base from '../../layouts/Base.astro'

const stats = await getStats()
const metrics = await getMetrics()
const politiker = await getPolitiker()
const beslutList = await getBeslut(200)
const budget = await getBudget()

// Politiker per nämnd — från grafen (ledamot_i edges)
const polPerNämnd = await fetchApi<
  Record<string, { id: string; namn: string; parti: string; roll: string; url: string }[]>
>('/api/v1/goteborg/graf/politiker-per-nämnd')
// Case-insensitive lookup map
const polPerNämndLower = new Map(
  Object.entries(polPerNämnd || {}).map(([k, v]) => [k.toLowerCase(), v]),
)

// Antal nämnder per politiker (ledamot_i, exkl. ersättare) — för (N:x)-suffixet
const nämndAntal = new Map<string, number>()
for (const pols of Object.values(polPerNämnd || {})) {
  for (const p of pols) nämndAntal.set(p.id, (nämndAntal.get(p.id) || 0) + 1)
}

const topNämnder = budget.nämnder
  .filter((n: any) => n.kommunbidragMnkr > 200 && !n.namn.includes('Reavinster'))
  .slice(0, 12)
  .map((n: any) => ({ ...n, politiker: polPerNämndLower.get(n.namn.toLowerCase()) || [] }))

// Samma partirankning (2022 KF-mandat, Valmyndigheten 2022-09-11) som
// /api/v1/goteborg/graf/politiker-per-nämnd använder för att sortera nämnd-listorna.
const officialSeats: Record<string, number> = {
  S: 21,
  M: 14,
  V: 13,
  SD: 9,
  MP: 5,
  L: 5,
  D: 5,
  KD: 4,
  C: 5,
}
const partiRank = new Map(
  Object.entries(officialSeats)
    .sort((a, b) => b[1] - a[1])
    .map(([p], i) => [p, i]),
)

// KF-ledamöter — sedan roster:et växte till 412 (KF + alla nämnd-only) räcker
// inte längre "de första 81 i alfabetisk ordning" (se seats nedan, som byggde
// på det antagandet och tystnat gick sönder). Filtrera på faktiskt uppdrag
// istället, som KS-listan.
const kfLedamöter = politiker
  .filter((p) =>
    (p.uppdrag || []).some(
      (u) => /Kommunfullmäktige/i.test(u.organisation) && /^Ledamot\b/i.test(u.roll),
    ),
  )
  .map((p) => ({ id: p.id, namn: p.namn, parti: p.parti }))
  .sort(
    (a, b) =>
      (partiRank.get(a.parti) ?? 99) - (partiRank.get(b.parti) ?? 99) ||
      a.namn.localeCompare(b.namn, 'sv'),
  )

// KS-ledamöter — samma källa (uppdrag) som nämnd/KF-filtret på /goteborg/politiker.
// Exakt organisation "Kommunstyrelsen" (inte Arbetsutskott/presidium), bara
// Ledamot-roller (inte Ersättare/Representant).
const ksLedamöter = politiker
  .filter((p) =>
    (p.uppdrag || []).some(
      (u) => u.organisation === 'Kommunstyrelsen' && /^Ledamot\b/i.test(u.roll),
    ),
  )
  .map((p) => ({
    id: p.id,
    namn: p.namn,
    parti: p.parti,
    ärKf: (p.uppdrag || []).some((u) => /Kommunfullmäktige/i.test(u.organisation)),
  }))
  .sort(
    (a, b) =>
      (partiRank.get(a.parti) ?? 99) - (partiRank.get(b.parti) ?? 99) ||
      a.namn.localeCompare(b.namn, 'sv'),
  )

// KS-medlemskap för (KS)-suffixet i KF-listan
const ksIds = new Set(ksLedamöter.map((p) => p.id))

const seats = kfLedamöter.map((p, i) => ({
  nummer: i + 1,
  politikerId: p.id,
  namn: p.namn,
  parti: p.parti,
}))

const partiMandat = Object.entries(stats.partier).map(([label, value]) => ({
  label,
  value,
  color: `var(--parti-${label.toLowerCase()})`,
}))

const partiNamn: Record<string, string> = {
  S: 'Socialdemokraterna',
  M: 'Moderaterna',
  SD: 'Sverigedemokraterna',
  V: 'Vänsterpartiet',
  MP: 'Miljöpartiet',
  C: 'Centerpartiet',
  L: 'Liberalerna',
  KD: 'Kristdemokraterna',
  D: 'Demokraterna',
}

const riceEntries = Object.entries(metrics.riceIndex || {}).sort(
  ([, a]: any, [, b]: any) => b - a,
) as [string, number][]

// Parti × parti röstöverensstämmelse — samma partiordning (mandatstorlek) som resten av sidan
const { partier: överensPartier, matris: överensMatris } = metrics.röstÖverensstämmelse || {
  partier: [],
  matris: [],
}
const överensOrdning = [...överensPartier].sort(
  (a, b) => (partiRank.get(a) ?? 99) - (partiRank.get(b) ?? 99),
)
const överensIndex = new Map(överensPartier.map((p: string, i: number) => [p, i]))
const överensMatrisSorterad = överensOrdning.map((a) =>
  överensOrdning.map((b) => överensMatris[överensIndex.get(a)!][överensIndex.get(b)!]),
)
const partiFärger = Object.fromEntries(
  överensOrdning.map((p) => [p, `var(--parti-${p.toLowerCase()})`]),
)

// Anföranden-trend: jämför de två senaste HELA åren (innevarande år pågår)
const anförandenPerÅr: { år: string; antal: number }[] = metrics.debatt.perÅr || []
const nuvarandeÅr = new Date().getFullYear().toString()
const helaÅr = anförandenPerÅr.filter((p) => p.år !== nuvarandeÅr)
const [föregående, senaste] = helaÅr.slice(-2)
const anförandenTrend =
  föregående && senaste
    ? {
        procent: Math.round(((senaste.antal - föregående.antal) / föregående.antal) * 100),
        label: `${föregående.år}→${senaste.år}`,
      }
    : null

const senasteBeslut = beslutList
  .filter((b) => b.beslut)
  .slice(0, 6)
  .map((b) => ({
    titel: b.rubrik.replace(/^§ \d+ /, ''),
    datum: b.datum,
    status: b.beslut === 'bordläggning' ? 'bordlagd' : b.beslut,
    paragraf: b.paragraf ? `KF ${b.paragraf}` : undefined,
    ja: b.votering?.ja,
    nej: b.votering?.nej,
    avstar: b.votering?.avstår,
    url: `/goteborg/beslut/${encodeURIComponent(b.id)}`,
  }))
---

<Base title="Göteborg">

  <!-- Header -->
  <section class="mb-12">
    <h1 class="text-4xl font-bold mb-2">Göteborg</h1>
    <p class="text-[var(--color-text-muted)]">Kommunfullmäktige — 81 ledamöter som beslutar för dig</p>
  </section>

  <!-- Chamber -->
  <section class="mb-12">
    <div class="mx-auto p-6 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)]">
      <Chamber seats={seats} mode="overview" />
    </div>
  </section>

  <!-- KPI row -->
  <section class="mb-12">
    <div class="grid gap-4 grid-cols-[repeat(auto-fit,minmax(180px,1fr))]">
      <Card title="Politiker" titleSize="sm">
        <div class="font-mono text-[2.5rem] font-bold leading-none text-[var(--color-text)]">{stats.politiker}</div>
      </Card>
      <Card title="Beslut (med status)" titleSize="sm">
        <div class="font-mono text-[2.5rem] font-bold leading-none text-[var(--color-text)]">{metrics.beslutskraft.totalt}</div>
      </Card>
      <Card title="Möten" titleSize="sm">
        <div class="font-mono text-[2.5rem] font-bold leading-none text-[var(--color-text)]">{metrics.närvaro.möten}</div>
      </Card>
      <Card title="Voteringar" titleSize="sm">
        <div class="font-mono text-[2.5rem] font-bold leading-none text-[var(--color-text)]">{metrics.konsensus.medVotering}</div>
      </Card>
    </div>
  </section>

  <!-- Struktur -->
  <section class="mb-12">
    <!-- Struktur -->
    <Card title="Hur styrs Göteborg?" titleSize="lg">
      <div class="flex flex-col gap-3">
        <OrgBlock
          title="Kommunfullmäktige (KF)"
          description='"Riksdagen för Göteborg" — 81 ledamöter fattar alla stora beslut'
          politiker={kfLedamöter.map((p) => ({ url: `/goteborg/politiker/${p.id}`, namn: p.namn, parti: p.parti, ärKs: ksIds.has(p.id), antalNämnder: nämndAntal.get(p.id) }))}
        />
        <OrgBlock
          title="Kommunstyrelsen (KS)"
          description='"Regeringen" — 13 ledamöter leder det dagliga arbetet'
          accent="var(--org-ks)"
          class="ml-6"
          politiker={ksLedamöter.map((p) => ({ url: `/goteborg/politiker/${p.id}`, namn: p.namn, parti: p.parti, ärKf: p.ärKf, antalNämnder: nämndAntal.get(p.id) }))}
        />
        {topNämnder.map((n: any) => (
          <OrgBlock
            title={n.namn}
            accent="var(--org-namnd)"
            class="ml-12"
            politiker={n.politiker.map((p: any) => ({
              url: `/goteborg/politiker/${p.id}`,
              namn: p.namn,
              parti: p.parti,
              ärKf: p.ärKf,
              antalNämnder: nämndAntal.get(p.id),
            }))}
          />
        ))}
      </div>
    </Card>
  </section>

  <!-- Democracy Scorecard -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-4">Demokratisk hälsa</h2>
    <p class="text-sm text-[var(--color-text-muted)] mb-4">Vetenskapliga nyckeltal baserade på Legislative Studies-forskning</p>
    <div class="grid gap-4 grid-cols-[repeat(auto-fit,minmax(220px,1fr))]">
      <Card title="Konsensus" subtitle="Ärenden utan votering" tooltip="Andel beslut som fattades utan formell omröstning — alla var överens. Över 85% kan tyda på att verklig debatt sker bakom stängda dörrar.">
        <div class="flex justify-center">
          <Gauge
            value={metrics.konsensus.konsensusgradProcent}
            unit="%"
            zones={[
              { from: 0, to: 85, color: 'var(--color-positive)' },
              { from: 85, to: 100, color: 'var(--color-warning)' },
            ]}
          />
        </div>
        {metrics.konsensus.konsensusgradProcent > 85 && (
          <div class="mt-2 text-xs font-semibold flex items-center gap-1 text-(--color-warning)">
            <Icon name="triangle-alert" size={14} />
            Hög — kan dölja brist på debatt
          </div>
        )}
      </Card>

      <Card title="Debatt-Gini" subtitle="0 = jämnt, 1 = få dominerar" tooltip="Gini-koefficient som mäter hur ojämnt fördelat talartiden är. 0 = alla politiker talar lika mycket. 1 = en enda person tar all tid. Baserat på 16 476 registrerade anföranden.">
        <div class="flex justify-center">
          <Gauge
            value={metrics.debatt.giniKoefficient}
            min={0}
            max={1}
            decimals={2}
            zones={[
              { from: 0, to: 0.5, color: 'var(--color-positive)' },
              { from: 0.5, to: 0.7, color: 'var(--color-warning)' },
              { from: 0.7, to: 1, color: 'var(--color-negative)' },
            ]}
          />
        </div>
        {metrics.debatt.giniKoefficient > 0.7 && (
          <div class="mt-2 text-xs font-semibold flex items-center gap-1 text-(--color-negative)">
            <Icon name="shield-alert" size={14} />
            Få politiker dominerar debatten
          </div>
        )}
      </Card>

      <Card title="Anföranden" subtitle={`${metrics.debatt.djupPerÄrende} per voteringsärende`} tooltip="Totalt antal registrerade talarturer i KF under mandatperioden. Fler anföranden per ärende tyder på djupare deliberation — men se Gini-koefficienten för hur jämnt de fördelas.">
        <KpiTrend
          value={metrics.debatt.anföranden.toLocaleString('sv-SE')}
          trend={anförandenTrend ? {
            text: `${anförandenTrend.procent > 0 ? '+' : ''}${anförandenTrend.procent}% ${anförandenTrend.label}`,
            direction: anförandenTrend.procent > 0 ? 'up' : anförandenTrend.procent < 0 ? 'down' : 'neutral',
          } : undefined}
          points={anförandenPerÅr.map((p) => p.antal)}
          pointLabels={anförandenPerÅr.length > 1 ? [anförandenPerÅr[0].år, anförandenPerÅr[anförandenPerÅr.length - 1].år] : undefined}
          note={anförandenPerÅr.some((p) => p.år === nuvarandeÅr) ? 'pågår' : undefined}
        />
      </Card>

      <Card title="Snitt närvarande" subtitle={`${metrics.närvaro.möten} möten (inkl. ersättare)`} tooltip="Genomsnittligt antal politiker som registrerats som närvarande per KF-sammanträde. Inkluderar både ordinarie ledamöter (81 st) och tjänstgörande ersättare. Skalan går till 81 — fullsatt sal utan ersättare." tooltipPosition="top-right">
        <div class="flex justify-center">
          <Gauge
            value={metrics.närvaro.snittPerMöte}
            min={0}
            max={81}
            zones={[
              { from: 0, to: 65, color: 'var(--color-negative)' },
              { from: 65, to: 75, color: 'var(--color-warning)' },
              { from: 75, to: 81, color: 'var(--color-positive)' },
            ]}
          />
        </div>
        {metrics.närvaro.snittPerMöte >= 75 && (
          <div class="mt-2 text-xs font-semibold flex items-center gap-1 text-(--color-positive)">
            <Icon name="circle-check" size={14} />
            Bra uppslutning
          </div>
        )}
      </Card>
    </div>

    <!-- Rice Index per parti -->
    <div class="mt-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4">
      <h3 class="font-bold mb-3">Parti-sammanhållning (Rice Index)</h3>
      <p class="text-xs text-[var(--color-text-muted)] mb-3">1.0 = alla röstar lika, 0.5 = splittrat. Källa: Rice (1924)</p>
      <HorizontalBar
        bars={riceEntries.map(([parti, rice]) => ({ label: partiNamn[parti] || parti, subtitle: String(stats.partier[parti] || ''), value: rice, color: `var(--parti-${parti.toLowerCase()})` }))}
        max={1}
      />
    </div>

    <!-- Röstöverensstämmelse parti × parti -->
    {överensOrdning.length > 1 && (
      <div class="mt-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4">
        <h3 class="font-bold mb-3">Röstöverensstämmelse mellan partier</h3>
        <p class="text-xs text-[var(--color-text-muted)] mb-3">
          Andel voteringar där partiernas majoritet röstade lika — visar koalitionsmönster som inte syns i beslutslistan.
        </p>
        <Heatmap labels={överensOrdning} matrix={överensMatrisSorterad} colors={partiFärger} unit="överensstämmelse" />
      </div>
    )}
  </section>

  <!-- Decision feed -->
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold">Senaste beslut</h2>
      <Button variant="ghost" href="/goteborg/beslut">Alla beslut →</Button>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {senasteBeslut.map(b => (
        <DecisionCard
          titel={b.titel}
          datum={b.datum}
          status={b.status}
          paragraf={b.paragraf}
          ja={b.ja}
          nej={b.nej}
          avstar={b.avstar}
          url={b.url}
        />
      ))}
    </div>
  </section>

</Base>
