---
import DecisionCard from '../../../../ui/src/components/cards/DecisionCard.astro'
import Chamber from '../../../../ui/src/components/charts/Chamber.astro'
import Donut from '../../../../ui/src/components/charts/Donut.astro'
import HorizontalBar from '../../../../ui/src/components/charts/HorizontalBar.astro'
import Button from '../../../../ui/src/components/core/Button.astro'
import Card from '../../../../ui/src/components/core/Card.astro'
import Icon from '../../../../ui/src/components/core/Icon.astro'
import { getBeslut, getBudget, getMetrics, getPolitiker, getStats } from '../../data/api'
import Base from '../../layouts/Base.astro'

const stats = await getStats()
const metrics = await getMetrics()
const politiker = await getPolitiker()
const beslutList = await getBeslut(200)
const budget = await getBudget()
const topNämnder = budget.nämnder
  .filter((n: any) => n.kommunbidragMnkr > 200 && !n.namn.includes('Reavinster'))
  .slice(0, 12)

const seats = politiker
  .slice(0, 81)
  .map((p, i) => ({ nummer: i + 1, politikerId: p.id, namn: p.namn, parti: p.parti }))

const partiMandat = Object.entries(stats.partier).map(([label, value]) => ({
  label,
  value,
  color: `var(--parti-${label.toLowerCase()})`,
}))

const partiNamn: Record<string, string> = {
  S: 'Socialdemokraterna',
  M: 'Moderaterna',
  SD: 'Sverigedemokraterna',
  V: 'Vänsterpartiet',
  MP: 'Miljöpartiet',
  C: 'Centerpartiet',
  L: 'Liberalerna',
  KD: 'Kristdemokraterna',
  D: 'Demokraterna',
}

const riceEntries = Object.entries(metrics.riceIndex || {}).sort(
  ([, a]: any, [, b]: any) => b - a,
) as [string, number][]

const senasteBeslut = beslutList
  .filter((b) => b.beslut)
  .slice(0, 6)
  .map((b) => ({
    titel: b.rubrik.replace(/^§ \d+ /, ''),
    datum: b.datum,
    status: b.beslut === 'bordläggning' ? 'bordlagd' : b.beslut,
    paragraf: b.paragraf ? `KF ${b.paragraf}` : undefined,
    ja: b.votering?.ja,
    nej: b.votering?.nej,
    avstar: b.votering?.avstår,
    url: `/goteborg/beslut/${encodeURIComponent(b.id)}`,
  }))
---

<Base title="Göteborg">

  <!-- Header -->
  <section class="mb-12">
    <h1 class="text-4xl font-bold mb-2">Göteborg</h1>
    <p class="text-[var(--color-text-muted)]">Kommunfullmäktige — 81 ledamöter som beslutar för dig</p>
  </section>

  <!-- Chamber -->
  <section class="mb-12">
    <div class="mx-auto p-6 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)]">
      <Chamber seats={seats} mode="overview" />
    </div>
  </section>

  <!-- KPI row -->
  <section class="mb-12">
    <div class="grid gap-4" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
      <Card title="Politiker" titleSize="sm">
        <div class="font-mono text-[2.5rem] font-bold leading-none text-[var(--color-text)]">{stats.politiker}</div>
      </Card>
      <Card title="Beslut (med status)" titleSize="sm">
        <div class="font-mono text-[2.5rem] font-bold leading-none text-[var(--color-text)]">{metrics.beslutskraft.totalt}</div>
      </Card>
      <Card title="Möten" titleSize="sm">
        <div class="font-mono text-[2.5rem] font-bold leading-none text-[var(--color-text)]">{metrics.närvaro.möten}</div>
      </Card>
      <Card title="Voteringar" titleSize="sm">
        <div class="font-mono text-[2.5rem] font-bold leading-none text-[var(--color-text)]">{metrics.konsensus.medVotering}</div>
      </Card>
    </div>
  </section>

  <!-- Two-column: Donut + Struktur -->
  <section class="mb-12 grid gap-8" style="grid-template-columns: 1fr 2fr;">
    <!-- Mandatfördelning -->
    <Card title="Mandatfördelning" titleSize="lg">
      <Donut segments={partiMandat} showValue unit="mandat" />
    </Card>

    <!-- Struktur -->
    <Card title="Hur styrs Göteborg?" titleSize="lg">
      <div class="flex flex-col gap-3">
        <div class="p-4 rounded-lg bg-[var(--color-surface-sunken)] border-l-4 border-l-[var(--color-primary)]">
          <h3 class="font-bold">Kommunfullmäktige (KF)</h3>
          <p class="text-sm text-[var(--color-text-muted)]">"Riksdagen för Göteborg" — 81 ledamöter fattar alla stora beslut</p>
        </div>
        <div class="ml-6 p-4 rounded-lg bg-[var(--color-surface-sunken)] border-l-4 border-l-violet-500">
          <h3 class="font-bold">Kommunstyrelsen (KS)</h3>
          <p class="text-sm text-[var(--color-text-muted)]">"Regeringen" — 13 ledamöter leder det dagliga arbetet</p>
        </div>
        <div class="ml-12 grid gap-2" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
          {topNämnder.map((n: any) => (
            <div class="p-3 rounded bg-[var(--color-surface-sunken)] text-sm">
              <span class="font-semibold">{n.namn}</span><br/>
              <span class="text-xs font-mono text-[var(--color-text-muted)]">{n.kommunbidragMnkr} mnkr</span>
            </div>
          ))}
        </div>
      </div>
    </Card>
  </section>

  <!-- Democracy Scorecard -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-4">Demokratisk hälsa</h2>
    <p class="text-sm text-[var(--color-text-muted)] mb-4">Vetenskapliga nyckeltal baserade på Legislative Studies-forskning</p>
    <div class="grid gap-4" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
      <Card title="Konsensus" subtitle="Ärenden utan votering" tooltip="Andel beslut som fattades utan formell omröstning — alla var överens. Över 85% kan tyda på att verklig debatt sker bakom stängda dörrar.">
        <div class="font-mono text-[2.5rem] font-bold leading-none"
          style={metrics.konsensus.konsensusgradProcent > 85 ? 'color:var(--color-warning)' : 'color:var(--color-text)'}
        >{metrics.konsensus.konsensusgradProcent}<span class="text-base ml-1 text-[var(--color-text-muted)]">%</span></div>
        {metrics.konsensus.konsensusgradProcent > 85 && (
          <div class="mt-2 text-xs font-semibold flex items-center gap-1" style="color:var(--color-warning)">
            <Icon name="triangle-alert" size={14} />
            Hög — kan dölja brist på debatt
          </div>
        )}
      </Card>

      <Card title="Debatt-Gini" subtitle="0 = jämnt, 1 = få dominerar" tooltip="Gini-koefficient som mäter hur ojämnt fördelat talartiden är. 0 = alla politiker talar lika mycket. 1 = en enda person tar all tid. Baserat på 16 476 registrerade anföranden.">
        <div class="font-mono text-[2.5rem] font-bold leading-none"
          style={metrics.debatt.giniKoefficient > 0.7 ? 'color:var(--color-negative)' : metrics.debatt.giniKoefficient > 0.5 ? 'color:var(--color-warning)' : 'color:var(--color-positive)'}
        >{metrics.debatt.giniKoefficient}</div>
        {metrics.debatt.giniKoefficient > 0.7 && (
          <div class="mt-2 text-xs font-semibold flex items-center gap-1" style="color:var(--color-negative)">
            <Icon name="shield-alert" size={14} />
            Få politiker dominerar debatten
          </div>
        )}
      </Card>

      <Card title="Anföranden" subtitle={`${metrics.debatt.djupPerÄrende} per voteringsärende`} tooltip="Totalt antal registrerade talarturer i KF under mandatperioden. Fler anföranden per ärende tyder på djupare deliberation — men se Gini-koefficienten för hur jämnt de fördelas.">
        <div class="font-mono text-[2.5rem] font-bold leading-none text-[var(--color-text)]">{metrics.debatt.anföranden.toLocaleString('sv-SE')}</div>
      </Card>

      <Card title="Snitt närvarande" subtitle={`${metrics.närvaro.möten} möten (inkl. ersättare)`} tooltip="Genomsnittligt antal politiker som registrerats som närvarande per KF-sammanträde. Inkluderar både ordinarie ledamöter (81 st) och tjänstgörande ersättare." tooltipPosition="top-right">
        <div class="font-mono text-[2.5rem] font-bold leading-none" style="color:var(--color-positive)">{metrics.närvaro.snittPerMöte}</div>
        <div class="mt-2 text-xs font-semibold flex items-center gap-1" style="color:var(--color-positive)">
          <Icon name="circle-check" size={14} />
          Bra uppslutning
        </div>
      </Card>
    </div>

    <!-- Rice Index per parti -->
    <div class="mt-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4">
      <h3 class="font-bold mb-3">Parti-sammanhållning (Rice Index)</h3>
      <p class="text-xs text-[var(--color-text-muted)] mb-3">1.0 = alla röstar lika, 0.5 = splittrat. Källa: Rice (1924)</p>
      <HorizontalBar
        bars={riceEntries.map(([parti, rice]) => ({ label: partiNamn[parti] || parti, subtitle: String(stats.partier[parti] || ''), value: rice, color: `var(--parti-${parti.toLowerCase()})` }))}
        max={1}
      />
    </div>
  </section>

  <!-- Decision feed -->
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold">Senaste beslut</h2>
      <Button variant="ghost" href="/goteborg/beslut">Alla beslut →</Button>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {senasteBeslut.map(b => (
        <DecisionCard
          titel={b.titel}
          datum={b.datum}
          status={b.status}
          paragraf={b.paragraf}
          ja={b.ja}
          nej={b.nej}
          avstar={b.avstar}
          url={b.url}
        />
      ))}
    </div>
  </section>

</Base>
