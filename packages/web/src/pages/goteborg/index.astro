---
import Base from '../../layouts/Base.astro'
import { generateChamberSVG, generateDonutSVG, partyColors } from '@daf/ui'
import { getMockSeats } from '../../data/mock'

const seats = getMockSeats()

const chamberSVG = generateChamberSVG({ seats, mode: 'overview' })

const partiMandat: [string, number][] = [
  ['S', 21], ['M', 16], ['SD', 14], ['V', 9],
  ['MP', 7], ['C', 5], ['L', 5], ['KD', 4],
]

const donutSVG = generateDonutSVG({
  segments: partiMandat.map(([parti, value]) => ({
    label: parti,
    value,
    color: partyColors[parti as keyof typeof partyColors],
  })),
  showLegend: true,
})

const kpis = [
  { value: '81', label: 'Ledamöter i KF' },
  { value: '234', label: 'Beslut 2025' },
  { value: '92%', label: 'Närvaro (snitt)' },
  { value: '12.4 mdr', label: 'Budget (kr)' },
]
---

<Base title="Göteborg" description="Göteborgs kommunfullmäktige — 81 ledamöter, beslut, voteringar">

  <!-- Block 1: Salen -->
  <section style="margin-bottom: var(--space-2xl);">
    <h1 style="font-size: var(--font-size-h1); font-weight: 700; margin-bottom: var(--space-sm);">Göteborg</h1>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-lg);">Kommunfullmäktige — 81 ledamöter som beslutar för dig</p>
    <div class="w-full max-w-2xl mx-auto" set:html={chamberSVG} />
  </section>

  <!-- Block 2: KPI -->
  <section style="margin-bottom: var(--space-2xl);">
    <div class="grid grid-cols-2 md:grid-cols-4" style="gap: var(--space-md);">
      {kpis.map(kpi => (
        <div style="text-align: center; padding: var(--space-md); border-radius: var(--radius-md); background: var(--color-surface); border: 1px solid var(--color-border);">
          <div style="font-size: var(--font-size-kpi); font-weight: 700; font-family: var(--font-mono);">{kpi.value}</div>
          <div style="font-size: var(--font-size-label); color: var(--color-text-muted);">{kpi.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Block 3: Partibalans -->
  <section style="margin-bottom: var(--space-2xl);">
    <h2 style="font-size: var(--font-size-h2); font-weight: 700; margin-bottom: var(--space-md);">Mandatfördelning</h2>
    <div class="w-full max-w-md" set:html={donutSVG} />
  </section>

  <!-- Block 4: Struktur -->
  <section style="margin-bottom: var(--space-2xl);">
    <h2 style="font-size: var(--font-size-h2); font-weight: 700; margin-bottom: var(--space-md);">Hur styrs Göteborg?</h2>
    <div style="display: flex; flex-direction: column; gap: var(--space-sm);">
      <div style="padding: var(--space-md); border-radius: var(--radius-md); background: var(--color-surface); border-left: 4px solid var(--color-primary);">
        <h3 style="font-size: var(--font-size-h3); font-weight: 700;">Kommunfullmäktige (KF)</h3>
        <p style="font-size: var(--font-size-label); color: var(--color-text-muted);">"Riksdagen för Göteborg" — 81 ledamöter fattar alla stora beslut</p>
      </div>
      <div style="margin-left: var(--space-lg); padding: var(--space-md); border-radius: var(--radius-md); background: var(--color-surface); border-left: 4px solid var(--color-accent);">
        <h3 style="font-size: var(--font-size-h3); font-weight: 700;">Kommunstyrelsen (KS)</h3>
        <p style="font-size: var(--font-size-label); color: var(--color-text-muted);">"Regeringen" — 13 ledamöter leder det dagliga arbetet</p>
      </div>
      <div style="margin-left: var(--space-2xl); display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: var(--space-sm);">
        <div style="padding: var(--space-sm) var(--space-md); border-radius: var(--radius-sm); background: var(--color-surface-sunken);">
          <span style="font-weight: 600; font-size: var(--font-size-label);">Grundskolenämnden</span><br/>
          <span style="font-size: var(--font-size-small); color: var(--color-text-muted);">Skolor & lärare</span>
        </div>
        <div style="padding: var(--space-sm) var(--space-md); border-radius: var(--radius-sm); background: var(--color-surface-sunken);">
          <span style="font-weight: 600; font-size: var(--font-size-label);">Byggnadsnämnden</span><br/>
          <span style="font-size: var(--font-size-small); color: var(--color-text-muted);">Vad som får byggas</span>
        </div>
        <div style="padding: var(--space-sm) var(--space-md); border-radius: var(--radius-sm); background: var(--color-surface-sunken);">
          <span style="font-weight: 600; font-size: var(--font-size-label);">Trafiknämnden</span><br/>
          <span style="font-size: var(--font-size-small); color: var(--color-text-muted);">Vägar & spårvagnar</span>
        </div>
        <div style="padding: var(--space-sm) var(--space-md); border-radius: var(--radius-sm); background: var(--color-surface-sunken);">
          <span style="font-weight: 600; font-size: var(--font-size-label);">Socialnämnden</span><br/>
          <span style="font-size: var(--font-size-small); color: var(--color-text-muted);">Stöd & omsorg</span>
        </div>
        <div style="padding: var(--space-sm) var(--space-md); border-radius: var(--radius-sm); background: var(--color-surface-sunken);">
          <span style="font-weight: 600; font-size: var(--font-size-label);">Miljönämnden</span><br/>
          <span style="font-size: var(--font-size-small); color: var(--color-text-muted);">Klimat & natur</span>
        </div>
        <a href="/goteborg/struktur" style="padding: var(--space-sm) var(--space-md); border-radius: var(--radius-sm); background: var(--color-surface-sunken); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: var(--font-size-label);">
          Visa alla →
        </a>
      </div>
    </div>
  </section>

  <!-- Block 5: Senaste beslut -->
  <section>
    <h2 style="font-size: var(--font-size-h2); font-weight: 700; margin-bottom: var(--space-md);">Senaste beslut</h2>
    <div style="display: flex; flex-direction: column; gap: var(--space-sm);">
      <article style="padding: var(--space-md); border-radius: var(--radius-md); border: 1px solid var(--color-border);">
        <div class="flex justify-between items-center" style="margin-bottom: var(--space-xs);">
          <span style="color: var(--color-positive); font-weight: 600; font-size: var(--font-size-label);">🟢 Bifall</span>
          <time style="font-size: var(--font-size-small); color: var(--color-text-muted);">2025-06-12</time>
        </div>
        <h3 style="font-size: var(--font-size-body); font-weight: 600;">Ny cykelväg Hisingen–centrum</h3>
        <p style="font-size: var(--font-size-label); color: var(--color-text-muted);">KF § 45 · Ja: 52 · Nej: 21 · Avstår: 8</p>
      </article>
      <article style="padding: var(--space-md); border-radius: var(--radius-md); border: 1px solid var(--color-border);">
        <div class="flex justify-between items-center" style="margin-bottom: var(--space-xs);">
          <span style="color: var(--color-negative); font-weight: 600; font-size: var(--font-size-label);">🔴 Avslag</span>
          <time style="font-size: var(--font-size-small); color: var(--color-text-muted);">2025-06-10</time>
        </div>
        <h3 style="font-size: var(--font-size-body); font-weight: 600;">Motion: Gratis kollektivtrafik under 26 år</h3>
        <p style="font-size: var(--font-size-label); color: var(--color-text-muted);">KF § 43 · Ja: 31 · Nej: 45 · Avstår: 5</p>
      </article>
      <article style="padding: var(--space-md); border-radius: var(--radius-md); border: 1px solid var(--color-border);">
        <div class="flex justify-between items-center" style="margin-bottom: var(--space-xs);">
          <span style="color: var(--color-neutral); font-weight: 600; font-size: var(--font-size-label);">📋 Remitterad</span>
          <time style="font-size: var(--font-size-small); color: var(--color-text-muted);">2025-06-08</time>
        </div>
        <h3 style="font-size: var(--font-size-body); font-weight: 600;">Budget 2026 — förslag från KS</h3>
        <p style="font-size: var(--font-size-label); color: var(--color-text-muted);">Skickat till alla nämnder för yttrande</p>
      </article>
    </div>
  </section>

</Base>
