---
import Donut from '../../../../ui/src/components/charts/Donut.astro'
import Card from '../../../../ui/src/components/core/Card.astro'
import { getBudget } from '../../data/api'
import Base from '../../layouts/Base.astro'

const budget = await getBudget()
const allPoster = budget.nämnder.filter((n: any) => n.kommunbidragMnkr)
  .sort((a: any, b: any) => b.kommunbidragMnkr - a.kommunbidragMnkr)

// Split: nämnder (≥10 mnkr) vs öronmärkta poster (<10 mnkr)
const nämnder = allPoster.filter((n: any) => n.kommunbidragMnkr >= 10)
const öronmärkta = allPoster.filter((n: any) => n.kommunbidragMnkr < 10)

// Donut: top 10 + rest
const top = nämnder.slice(0, 10)
const rest = nämnder.slice(10)
const övrigtSum = rest.reduce((s: number, n: any) => s + n.kommunbidragMnkr, 0)

const colors = [
  'var(--color-primary)',
  '#e67e22',
  '#9b59b6',
  '#2ecc71',
  '#e74c3c',
  '#3498db',
  '#1abc9c',
  '#f39c12',
  '#8e44ad',
  '#16a085',
  'var(--color-text-subtle)',
]

const segments = [
  ...top.map((n: any, i: number) => ({
    label: n.namn,
    value: n.kommunbidragMnkr,
    color: colors[i],
  })),
  ...(övrigtSum > 0 ? [{ label: `Övrigt (${rest.length} poster)`, value: övrigtSum, color: colors[10] }] : []),
]
---

<Base title="Budget — Göteborg">
  <h1 class="text-[2rem] font-bold mb-2">Budget 2026</h1>
  <p class="text-sm text-[var(--color-text-muted)] mb-8">
    Göteborgs Stads kommunbidrag — totalt <strong class="font-mono">{budget.totalMnkr.toLocaleString('sv-SE')}</strong> mnkr.
    Antagen av KF (S+V+MP).
  </p>

  <div class="grid gap-8">
    <Card>
      <Donut segments={segments} size={360} thickness={60} showValue showAbsoluteValue legend unit="mnkr" />
    </Card>

    {öronmärkta.length > 0 && (
    <Card title="Öronmärkta poster" titleSize="lg" subtitle="Riktade satsningar och transfereringar">
      <div class="space-y-1 text-sm">
        {öronmärkta.map((n: any) => (
          <div class="flex items-center gap-3 py-1">
            <span class="truncate flex-1 text-[var(--color-text-muted)]">{n.namn}</span>
            <span class="font-mono shrink-0">{n.kommunbidragMnkr.toLocaleString('sv-SE')} <span class="text-[var(--color-text-muted)]">mnkr</span></span>
            <span class="text-[var(--color-text-muted)] w-12 text-right shrink-0">{n.andelProcent}%</span>
          </div>
        ))}
      </div>
    </Card>
    )}
  </div>
</Base>
