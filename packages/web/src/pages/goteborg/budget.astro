---
import Donut from '../../../../ui/src/components/charts/Donut.astro'
import ProgressBar from '../../../../ui/src/components/charts/ProgressBar.astro'
import StackedAreaChart from '../../../../ui/src/components/charts/StackedAreaChart.astro'
import Card from '../../../../ui/src/components/core/Card.astro'
import { type BudgetUtfallNämnd, getBudget, getBudgetUtfall, getBudgetYear } from '../../data/api'
import Kommun from '../../layouts/Kommun.astro'

const budget = await getBudget()
const allPoster = budget.nämnder
  .filter((n: any) => n.kommunbidragMnkr)
  .sort((a: any, b: any) => b.kommunbidragMnkr - a.kommunbidragMnkr)

// Split: nämnder (≥10 mnkr) vs öronmärkta poster (<10 mnkr)
const nämnder = allPoster.filter((n: any) => n.kommunbidragMnkr >= 10)
const öronmärkta = allPoster.filter((n: any) => n.kommunbidragMnkr < 10)

// Donut: top 10 + rest
const top = nämnder.slice(0, 10)
const rest = nämnder.slice(10)
const övrigtSum = rest.reduce((s: number, n: any) => s + n.kommunbidragMnkr, 0)

// Categorical palette from tokens/css/global.css; last color = "Övrigt"
const colors = [
  ...Array.from({ length: 10 }, (_, i) => `var(--chart-${i + 1})`),
  'var(--color-text-subtle)',
]

const segments = [
  ...top.map((n: any, i: number) => ({
    label: n.namn,
    value: n.kommunbidragMnkr,
    color: colors[i],
  })),
  ...(övrigtSum > 0
    ? [{ label: `Övrigt (${rest.length} poster)`, value: övrigtSum, color: colors[10] }]
    : []),
]

// --- Stacked Area Chart: budget per kategori 2022-2026 ---
const years = [2022, 2023, 2024, 2025, 2026]
const budgets = await Promise.all(years.map((y) => getBudgetYear(y)))

// --- Budgetutfall (senaste bokslutsår — 2026 är plan, inget utfall ännu) ---
const utfallÅr = 2025
const utfall = (await getBudgetUtfall(utfallÅr))
  .filter((u) => u.kommunbidragMnkr > 0)
  .sort((a, b) => b.kommunbidragMnkr - a.kommunbidragMnkr)

const utfallColor: Record<string, string> = {
  i_balans: 'var(--color-positive)',
  överskott: 'var(--color-positive)',
  stort_överskott: 'var(--color-positive)',
  underskott: 'var(--color-negative)',
  stort_underskott: 'var(--color-negative)',
}

// Nämnder finansieras av kommunbidrag + egna intäkter (avgifter m.m.) —
// jämför kostnader mot summan av båda, inte bara kommunbidraget.
function budgetutnyttjandeProcent(u: BudgetUtfallNämnd) {
  const finansiering = u.kommunbidragMnkr + u.intäkterMnkr
  return finansiering > 0 ? (Math.abs(u.kostnaderMnkr) / finansiering) * 100 : 0
}

// Gruppera nämnder i kategorier
const kategorier: Record<string, { label: string; match: RegExp; color: string }> = {
  skola: {
    label: 'Skola & förskola',
    match: /Förskole|Grundskole|Utbildnings/,
    color: 'var(--chart-1)',
  },
  omsorg: {
    label: 'Omsorg & funktionsstöd',
    match: /Äldre|omsorg|funktionsstöd/i,
    color: 'var(--chart-2)',
  },
  social: { label: 'Socialnämnderna', match: /Socialnämnd/, color: 'var(--chart-3)' },
  stadsmiljö: {
    label: 'Stadsmiljö & trafik',
    match: /Stadsmiljö|Trafik|Park-/,
    color: 'var(--chart-8)',
  },
  kultur: { label: 'Kultur & idrott', match: /Kultur|Idrotts/, color: 'var(--chart-6)' },
  övrigt: { label: 'Övrigt', match: /.*/, color: 'var(--color-neutral)' },
}

const katKeys = Object.keys(kategorier)
const seriesData = katKeys.map((key) => {
  const kat = kategorier[key]
  const values = budgets.map((b) => {
    const matchingNämnder = b.nämnder.filter((n: any) => {
      if (key === 'övrigt') {
        return !Object.entries(kategorier).some(([k, v]) => k !== 'övrigt' && v.match.test(n.namn))
      }
      return kat.match.test(n.namn)
    })
    return matchingNämnder.reduce((sum: number, n: any) => sum + (n.kommunbidragMnkr || 0), 0)
  })
  return { name: kat.label, values, color: kat.color }
})
---

<Kommun title="Budget — Göteborg">
  <h1 class="text-[2rem] font-bold mb-2">Budget 2026</h1>
  <p class="text-sm text-[var(--color-text-muted)] mb-8">
    Göteborgs Stads kommunbidrag — totalt <strong class="font-mono">{budget.totalMnkr.toLocaleString('sv-SE')}</strong> mnkr.
    Antagen av KF ({budget.styre}){budget.beslut && (
      <>
        {' '}
        —{' '}
        <a href={budget.beslut._links.self.href} class="underline hover:no-underline">
          {budget.beslut.label} ({budget.beslut.datum})
        </a>
      </>
    )}.
  </p>

  <div class="grid gap-8">
    <Card>
      <Donut segments={segments} size={360} thickness={60} showValue showAbsoluteValue legend unit="mnkr" />
    </Card>

    <Card title="Budget per kategori 2022–2026" titleSize="lg" subtitle="Kommunbidrag (mnkr) — utveckling över tid">
      <StackedAreaChart series={seriesData} categories={years.map(String)} unit="mnkr" />
    </Card>

    {utfall.length > 0 && (
      <Card title={`Budgetutfall ${utfallÅr}`} titleSize="lg" subtitle="Faktiska kostnader mot beviljat kommunbidrag — senaste bokslut">
        <div class="grid gap-4">
          {utfall.map((u) => (
            <ProgressBar
              label={u.nämnd}
              value={budgetutnyttjandeProcent(u)}
              valueLabel={`${Math.round(budgetutnyttjandeProcent(u))}% · ${u.resultatMnkr > 0 ? '+' : ''}${u.resultatMnkr} mnkr`}
              color={utfallColor[u.status] || 'var(--color-primary)'}
            />
          ))}
        </div>
      </Card>
    )}

    {öronmärkta.length > 0 && (
    <Card title="Öronmärkta poster" titleSize="lg" subtitle="Riktade satsningar och transfereringar">
      <div class="space-y-1 text-sm">
        {öronmärkta.map((n: any) => (
          <div class="flex items-center gap-3 py-1">
            <span class="truncate flex-1 text-[var(--color-text-muted)]">{n.namn}</span>
            <span class="font-mono shrink-0">{n.kommunbidragMnkr.toLocaleString('sv-SE')} <span class="text-[var(--color-text-muted)]">mnkr</span></span>
            <span class="text-[var(--color-text-muted)] w-12 text-right shrink-0">{n.andelProcent}%</span>
          </div>
        ))}
      </div>
    </Card>
    )}
  </div>
</Kommun>
