---
import Base from '../../../layouts/Base.astro'
---
<Base title="KF — Göteborg">
  <h1 class="text-[2rem] font-bold mb-2">Kommunfullmäktige</h1>
  <p class="text-sm text-[var(--color-text-muted)] mb-8">Göteborgs Stad — 81 ledamöter</p>
  <div class="grid gap-4 sm:grid-cols-2">
    <a href="/goteborg/kf/moten" class="p-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-primary)] transition-colors">
      <div class="text-2xl mb-2">📅</div>
      <h2 class="font-bold text-lg mb-1">Möten</h2>
      <p class="text-sm text-[var(--color-text-muted)]">Lista över alla KF-sammanträden med beslut och debatter</p>
    </a>
    <a href="/goteborg/kf/beslut" class="p-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-primary)] transition-colors">
      <div class="text-2xl mb-2">📋</div>
      <h2 class="font-bold text-lg mb-1">Beslut</h2>
      <p class="text-sm text-[var(--color-text-muted)]">Sökbar tabell med alla KF-beslut, voteringar och ärendenummer</p>
    </a>
    <a href="/goteborg/debatter" class="p-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-primary)] transition-colors">
      <div class="text-2xl mb-2">🎤</div>
      <h2 class="font-bold text-lg mb-1">Debatter</h2>
      <p class="text-sm text-[var(--color-text-muted)]">Yttrandeprotokoll — vem sa vad i varje debatt</p>
    </a>
  </div>
</Base>
