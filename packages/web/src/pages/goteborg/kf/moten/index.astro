---
import { getMöten } from '../../../../data/api'
import Base from '../../../../layouts/Base.astro'

const allMöten = await getMöten()
const möten = allMöten
  .filter((m: any) => m.label?.includes('KF'))
  .sort((a: any, b: any) => b.datum.localeCompare(a.datum))
---

<Base title="KF Möten — Göteborg">
  <h1 class="text-[2rem] font-bold mb-2">KF Sammanträden</h1>
  <p class="text-sm text-[var(--color-text-muted)] mb-8">
    Kommunfullmäktige — {möten.length} sammanträden med beslut och debatt
  </p>

  <div class="grid gap-2">
    {möten.map((m: any) => (
      <a
        href={`/goteborg/kf/moten/${m.datum}`}
        class="flex items-center justify-between p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] transition-colors"
      >
        <div class="flex items-center gap-4">
          <span class="font-mono font-semibold">{m.datum}</span>
          <span class="text-sm text-[var(--color-text-muted)]">{m.antalBeslut} beslut</span>
        </div>
        <span class="text-[var(--color-text-muted)]">→</span>
      </a>
    ))}
  </div>
</Base>
