---
import PartyTag from '../../../../../ui/src/components/core/PartyTag.astro'
import { getDebatt, getDebatter } from '../../../data/api'
import Base from '../../../layouts/Base.astro'

export async function getStaticPaths() {
  const debatter = await getDebatter()
  return debatter.möten.map((m) => ({ params: { datum: m.datum } }))
}

const { datum } = Astro.params
const debatt = await getDebatt(datum!)

if (!debatt) return Astro.redirect('/goteborg/debatter')

// Group by ärende
const byÄrende = new Map<number | null, typeof debatt.anföranden>()
for (const a of debatt.anföranden) {
  const key = a.ärende
  if (!byÄrende.has(key)) byÄrende.set(key, [])
  byÄrende.get(key)!.push(a)
}

// Party distribution
const partiCount: Record<string, number> = {}
for (const a of debatt.anföranden) {
  partiCount[a.parti] = (partiCount[a.parti] || 0) + 1
}
const topPartier = Object.entries(partiCount).sort((a, b) => b[1] - a[1])
---

<Base title={`KF ${datum} — Debatter`}>
  <div class="mb-6">
    <a href="/goteborg/debatter" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)]">← Alla debatter</a>
  </div>

  <h1 class="text-[2rem] font-bold mb-1">Kommunfullmäktige</h1>
  <p class="font-mono text-[var(--color-text-muted)] mb-4">{datum}</p>

  <div class="flex flex-wrap gap-2 mb-8">
    <span class="text-sm text-[var(--color-text-muted)]">{debatt.antal} anföranden</span>
    <span class="text-sm text-[var(--color-text-muted)]">·</span>
    <span class="text-sm text-[var(--color-text-muted)]">{byÄrende.size} ärenden</span>
    <span class="text-sm text-[var(--color-text-muted)]">·</span>
    {topPartier.map(([parti, count]) => (
      <span class="inline-flex items-center gap-1 text-xs">
        <PartyTag parti={parti} size="sm" />
        <span class="text-[var(--color-text-muted)]">{count}</span>
      </span>
    ))}
  </div>

  <!-- Search -->
  <div class="mb-6">
    <input id="search" type="text" placeholder="Sök i anföranden…"
      class="w-full max-w-md px-4 py-2 border border-[var(--color-border)] rounded-lg bg-[var(--color-surface)] text-[var(--color-text)] font-sans" />
  </div>

  <!-- Anföranden grouped by ärende -->
  <div id="anforanden-list" class="flex flex-col gap-6">
    {[...byÄrende.entries()].map(([ärendeNr, anfs]) => (
      <section>
        {ärendeNr !== null && (
          <h2 class="text-sm font-bold text-[var(--color-text-muted)] mb-3 pb-1 border-b border-[var(--color-border)]">
            {ärendeNr}. {anfs[0].ärendeTitel}
          </h2>
        )}
        <div class="flex flex-col gap-3">
          {anfs.map((a) => (
            <div class="anforande p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg">
              <div class="flex items-center gap-2 mb-2">
                <PartyTag parti={a.parti} size="sm" />
                <span class="font-semibold text-sm">{a.talare}</span>
              </div>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{a.text}</p>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</Base>

<script is:inline>
  const input = document.getElementById('search')
  const items = document.querySelectorAll('.anforande')

  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase()
    items.forEach(el => {
      const text = el.textContent?.toLowerCase() || ''
      el.classList.toggle('hidden', q.length > 0 && !text.includes(q))
    })
  })
</script>
