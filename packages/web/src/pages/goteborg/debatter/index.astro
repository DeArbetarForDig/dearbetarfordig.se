---
import { getDebatter } from '../../../data/api'
import Base from '../../../layouts/Base.astro'

const debatter = await getDebatter()
---

<Base title="KF Debatter — Göteborg">
  <h1 class="text-[2rem] font-bold mb-2">KF Debatter</h1>
  <p class="text-sm text-[var(--color-text-muted)] mb-8">
    Kommunfullmäktige — yttrandeprotokoll från {debatter.antal} sammanträden
  </p>

  <div class="grid gap-2">
    {debatter.möten.map((m) => (
      <a href={`/goteborg/debatter/${m.datum}`}
        class="flex items-center justify-between p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] transition-colors">
        <div>
          <span class="font-semibold font-mono">{m.datum}</span>
          <span class="ml-3 text-sm text-[var(--color-text-muted)]">Kommunfullmäktige</span>
        </div>
        <span class="text-[var(--color-text-muted)] text-sm">→</span>
      </a>
    ))}
  </div>
</Base>
