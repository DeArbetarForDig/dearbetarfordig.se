---
import DataTable from '../../../../../ui/src/components/core/DataTable.astro'
import Icon from '../../../../../ui/src/components/core/Icon.astro'
import { getBeslut } from '../../../data/api'
import Base from '../../../layouts/Base.astro'

const allBeslut = await getBeslut(2000)
const data = allBeslut.map((b) => {
  const status = b.beslut === 'bordläggning' ? 'Bordlagd' : b.beslut === 'bifall' ? 'Bifall' : b.beslut === 'avslag' ? 'Avslag' : ''
  const statusColor = b.beslut === 'bifall' ? 'var(--color-positive)' : b.beslut === 'avslag' ? 'var(--color-negative)' : b.beslut === 'bordläggning' ? 'var(--color-warning)' : ''
  const titel = b.rubrik?.replace(/^§ \d+ /, '') || ''
  const votering = b.votering ? `${b.votering.ja}/${b.votering.nej}` : ''
  return {
    paragraf: b.paragraf || '',
    datum: b.datum,
    titel,
    status,
    votering,
    _titel_html: `<a href="/goteborg/beslut/${encodeURIComponent(b.id)}" class="text-[var(--color-text)] no-underline hover:text-[var(--color-primary)]">${titel}</a>`,
    _status_html: statusColor ? `<span style="color:${statusColor};font-weight:600">${status}</span>` : '—',
    _votering_html: votering ? `<span class="font-mono"><span style="color:var(--color-positive)">${b.votering.ja}</span>/<span style="color:var(--color-negative)">${b.votering.nej}</span>${(b as any).namnupprop ? ' <svg style="display:inline;vertical-align:-2px" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--color-positive)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></svg>' : ''}</span>` : '',
  }
})

const columns = [
  { key: 'paragraf', label: '§', sort: 'default' as const, nowrap: true, width: '80px' },
  { key: 'datum', label: 'Datum', sort: 'date' as const, nowrap: true, width: '120px' },
  { key: 'titel', label: 'Ärende', sort: 'default' as const },
  { key: 'status', label: 'Status', sort: 'default' as const, nowrap: true, width: '120px' },
  { key: 'votering', label: 'Votering', sort: 'default' as const, nowrap: true, width: '120px' },
]
---

<Base title="Beslut — Göteborg">
  <h1 class="text-[2rem] font-bold mb-2">Beslut</h1>
  <p class="text-sm text-[var(--color-text-muted)] mb-6">{data.length} ärenden</p>
  <DataTable columns={columns} data={data} pageSize={20} />
</Base>
