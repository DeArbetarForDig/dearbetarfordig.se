---
/**
 * Base — generic page chrome: sysbar (brand + theme), content column, footer.
 *
 * Knows nothing about any kommun. Pages inside a kommun use the Kommun
 * layout, which fills the named slots here:
 * - "location": context chip in the sysbar (e.g. "Göteborg")
 * - "nav": sidebar content; when present, Base renders the nav rail
 *   (mobile: off-canvas drawer + hamburger + scrim, wired up below)
 *
 * Without a "nav" slot (landing page, /integritet) there is no sidebar and
 * the content column takes the full width.
 */
import '../styles/global.css'
import Breadcrumb from '../../../ui/src/components/core/Breadcrumb.astro'
import ChartTooltip from '../../../ui/src/components/core/ChartTooltip.astro'
import Icon from '../../../ui/src/components/core/Icon.astro'

interface Props {
  title: string
  description?: string
  breadcrumbs?: { label: string; href?: string }[]
}

const {
  title,
  description = 'Öppen demokratiplattform för svenska kommuner',
  breadcrumbs,
} = Astro.props

const hasNav = Astro.slots.has('nav')
const canonicalUrl = new URL(Astro.url.pathname, Astro.site)
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="content-language" content="sv" />
    <meta name="description" content={description} />
    <meta property="og:locale" content="sv_SE" />
    <title>{title} — De Arbetar För Dig</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={`${title} — De Arbetar För Dig`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="service-desc"
      type="application/vnd.oai.openapi+json"
      href="https://api.dearbetarfordig.se/openapi.json"
      title="API (OpenAPI)"
    />
    <link
      rel="alternate"
      type="application/vnd.oai.openapi+json"
      href="https://api.dearbetarfordig.se/openapi.json"
      title="API (OpenAPI)"
    />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-instruktioner" />
    <script is:inline>
      // Theme: restore from localStorage or use system preference
      const t = localStorage.getItem('theme')
      if (t) document.documentElement.setAttribute('data-theme', t)
      else if (window.matchMedia('(prefers-color-scheme: dark)').matches)
        document.documentElement.setAttribute('data-theme', 'dark')
      else document.documentElement.setAttribute('data-theme', 'light')
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased">

    <!-- Sysbar -->
    <header class="sysbar">
      <div class="sysbar__left">
        {hasNav && (
          <button
            id="nav-toggle"
            class="sysbar__menu-btn"
            aria-label="Öppna menyn"
            aria-controls="app-nav"
            aria-expanded="false"
          >
            <Icon name="menu" size={18} />
          </button>
        )}
        <a href="/" class="sysbar__brand">
          <span class="sysbar__product">DeArbetarFörDig</span>
        </a>
        <slot name="location" />
      </div>
      <div class="sysbar__right">
        <button id="theme-toggle" class="sysbar__item sysbar__theme-btn" aria-label="Byt tema">
          <span class="theme-icon-light"><Icon name="sun" size={16} /></span>
          <span class="theme-icon-dark"><Icon name="moon" size={16} /></span>
        </button>
      </div>
    </header>

    <!-- App shell: optional nav rail + content -->
    <div class="app">
      {hasNav && (
        <>
          <aside class="app__nav" id="app-nav">
            <slot name="nav" />
          </aside>
          <button class="app__scrim" id="nav-scrim" aria-label="Stäng menyn" tabindex="-1"></button>
        </>
      )}

      <div class="app__content">
        <main class="max-w-6xl mx-auto w-full flex-1 py-(--space-xl) px-(--space-md)">
          {breadcrumbs && breadcrumbs.length > 0 && (
            <Breadcrumb items={breadcrumbs} class="mb-4" />
          )}
          <slot />
        </main>

        <footer class="site-footer">
          <p>Public money, public code. Public decisions, public data.</p>
          <p class="mt-(--space-sm)">AGPL-3.0 · <a href="https://github.com/DeArbetarForDig/dearbetarfordig.se">Källkod</a> · <a href="https://api.dearbetarfordig.se/openapi.json">API</a> · <a href="/integritet">Integritet</a></p>
        </footer>
      </div>
    </div>

    <ChartTooltip />

    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme')
        const next = current === 'dark' ? 'light' : 'dark'
        document.documentElement.setAttribute('data-theme', next)
        localStorage.setItem('theme', next)
      })

      // Mobile nav drawer — only wired when the page has a nav rail
      const navToggle = document.getElementById('nav-toggle')
      if (navToggle) {
        const setNavOpen = (open) => {
          document.documentElement.toggleAttribute('data-nav-open', open)
          navToggle.setAttribute('aria-expanded', String(open))
        }
        navToggle.addEventListener('click', () =>
          setNavOpen(!document.documentElement.hasAttribute('data-nav-open')),
        )
        document.getElementById('nav-scrim').addEventListener('click', () => setNavOpen(false))
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') setNavOpen(false)
        })
      }
    </script>
  </body>
</html>
