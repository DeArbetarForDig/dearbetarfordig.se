---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Öppen demokratiplattform för svenska kommuner' } = Astro.props
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="content-language" content="sv" />
    <meta name="description" content={description} />
    <meta property="og:locale" content="sv_SE" />
    <title>{title} — De Arbetar För Dig</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <!-- System layer -->
    <header style="border-bottom: 1px solid var(--color-border); padding: var(--space-sm) var(--space-md);">
      <nav class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" style="font-weight: 700; font-size: var(--font-size-h3); color: var(--color-text); text-decoration: none;">DeArbetarFörDig</a>
        <ul class="flex gap-4" style="font-size: var(--font-size-label);">
          <li><a href="/goteborg">Göteborg</a></li>
        </ul>
      </nav>
    </header>

    <!-- Content layer -->
    <main class="max-w-6xl mx-auto w-full flex-1" style="padding: var(--space-xl) var(--space-md);">
      <slot />
    </main>

    <footer style="border-top: 1px solid var(--color-border); padding: var(--space-lg) var(--space-md); text-align: center; font-size: var(--font-size-label); color: var(--color-text-muted);">
      <p>Public money, public code. Public decisions, public data.</p>
      <p style="margin-top: var(--space-sm);">AGPL-3.0 · <a href="https://github.com/YOUR_ORG/dearbetarfordig.se">Källkod</a></p>
    </footer>
  </body>
</html>
