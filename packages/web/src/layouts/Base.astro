---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Öppen demokratiplattform för svenska kommuner' } = Astro.props
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="content-language" content="sv" />
    <meta name="description" content={description} />
    <meta property="og:locale" content="sv_SE" />
    <title>{title} — De Arbetar För Dig</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-white text-slate-800 dark:bg-slate-900 dark:text-slate-100 antialiased">
    <header class="border-b border-slate-200 dark:border-slate-700 px-4 py-3">
      <nav class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="font-bold text-lg">DeArbetarFörDig</a>
        <ul class="flex gap-4 text-sm">
          <li><a href="/goteborg">Göteborg</a></li>
        </ul>
      </nav>
    </header>
    <main class="max-w-6xl mx-auto px-4 py-8">
      <slot />
    </main>
    <footer class="border-t border-slate-200 dark:border-slate-700 px-4 py-6 mt-12 text-center text-sm text-slate-500">
      <p>Public money, public code. Public decisions, public data.</p>
      <p class="mt-1">AGPL-3.0 · <a href="https://github.com/YOUR_ORG/dearbetarfordig.se" class="underline">Källkod</a></p>
    </footer>
  </body>
</html>
