# === De Arbetar För Dig — Environment ===

# API
PORT=3000
NODE_ENV=development

# Database (production)
DATABASE_URL=postgresql://daf:password@localhost:5432/daf

# Used by docker-compose.yml on the server (interpolated raw into
# DATABASE_URL — no URL-encoding happens) — generate with:
#   openssl rand -hex 32
# NOT `-base64`: base64 can contain '/' and '+', which corrupt the
# postgresql:// URL the password gets embedded in. Never commit the real
# .env (gitignored).
POSTGRES_PASSWORD=

# Hosting
DEPLOY_HOST=your-server.hetzner.com
DEPLOY_USER=deploy
