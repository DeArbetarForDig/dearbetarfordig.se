    {
      "id": "ks-2024-10-16-§844",
      "typ": "paragraf",
      "label": "§ 844 Delårsrapport per augusti 2024",
      "data": {
        "paragrafNr": "844",
        "ärendeNr": "SLK-2024-00684",
        "rubrik": "Delårsrapport per augusti 2024",
        "fulltext": "§ 844 Ärendenummer SLK-2024-00684\nDelårsrapport per augusti 2024\nBeslut\n\nKommunstyrelsen tillstyrker stadsledningskontorets förslag och föreslår att\nkommunfullmäktige beslutar:\nGöteborgs Stads delårsbokslut per augusti 2024, i enlighet med bilagan till\nstadsledningskontorets tjänsteutlåtande, godkänns.\n\nHandling\n\nStadsledningskontorets tjänsteutlåtande den 7 oktober 2024.\n\nProtokollsutdrag skickas till\nKF Handling 2024 nr 192",
        "datum": "2024-10-16",
        "organ": "Kommunstyrelsen",
        "beslut": "tillstyrkan_kf",
        "yrkanden": [],
        "reservationer": []
      }
    }
